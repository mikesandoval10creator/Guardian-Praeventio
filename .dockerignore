# .dockerignore — applies to every `docker build` (legacy ./Dockerfile,
# Dockerfile.api, Dockerfile.frontend). Keep the build context small.

# ── VCS / IDE ────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.github/
.vscode/
.idea/

# ── Local secrets ────────────────────────────────────────────────────────
.env
.env.*
!.env.example
# H3 (2026-05-17): excluir firebase-applet-config para que un dev con el
# archivo local no lo hornee en la imagen. En runtime se monta como
# Secret Manager (Cloud Run). Ver docs/runbooks/SECRETS_RUNBOOK.md.
firebase-applet-config.json

# ── Node ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.eslintcache

# ── Build artefacts produced inside the image ────────────────────────────
dist/
build/
out/
.next/
coverage/
.nyc_output/

# ── Tests / dev tooling not needed at runtime ────────────────────────────
tests/
e2e/
playwright-report/
test-results/
.stryker-tmp/

# ── Agent scratch / telemetry ────────────────────────────────────────────
.claude/
.telemetry/
.cursor/

# ── Docs ─────────────────────────────────────────────────────────────────
docs/
*.md
!README.md

# ── Tools / scripts not needed at runtime ────────────────────────────────
tools/

# ── Mobile shells ────────────────────────────────────────────────────────
android/
ios/
fastlane/
*.apk
*.aab
*.ipa

# ── Misc ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
