# .dockerignore — applies to every `docker build` (legacy ./Dockerfile,
# Dockerfile.api, Dockerfile.frontend). Keep the build context small.

# ── VCS / IDE ────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.github/
.vscode/
.idea/

# ── Local secrets ────────────────────────────────────────────────────────
.env
.env.*
!.env.example
# firebase-applet-config.json is NOT excluded: it is the PUBLIC Firebase client
# config (projectId/apiKey/authDomain/firestoreDatabaseId — no SA private key;
# the admin credential is ADC / Workload Identity). vite bundles it into the
# client AND server.ts reads it at startup to select the non-default Firestore
# database. Excluding it broke both the build and the runtime DB selection.

# ── Node ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.eslintcache

# ── Build artefacts produced inside the image ────────────────────────────
dist/
build/
out/
.next/
coverage/
.nyc_output/

# ── Tests / dev tooling not needed at runtime ────────────────────────────
tests/
e2e/
playwright-report/
test-results/
.stryker-tmp/

# ── Agent scratch / telemetry ────────────────────────────────────────────
.claude/
.telemetry/
.cursor/

# ── Docs ─────────────────────────────────────────────────────────────────
docs/
*.md
!README.md

# ── Tools / scripts not needed at runtime ────────────────────────────────
tools/

# ── Mobile shells ────────────────────────────────────────────────────────
android/
ios/
fastlane/
*.apk
*.aab
*.ipa

# ── Misc ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
