# Sprint 21 Ola 6 — Bucket S — Ruby deps for Fastlane mobile signing pipeline.
#
# Run `bundle install` once locally to generate Gemfile.lock (committed
# alongside this file in CI). The mobile-release workflow uses
# `ruby/setup-ruby@v1` with `bundler-cache: true`, which re-uses Gemfile.lock
# for reproducible installs across runs.
#
# To run lanes locally:
#   gem install bundler
#   bundle install
#   bundle exec fastlane android build_only   # smoke test, no upload
#   bundle exec fastlane android internal     # signed + Play Internal upload
#
# See docs/mobile-build-runbook.md §6 for the full local + CI setup.

source "https://rubygems.org"

gem "fastlane"
