    "@react-three/rapier": "^2.2.0",
    "@sentry/node": "^10.51.0",
    "@sentry/react": "^10.51.0",
    "@simplewebauthn/server": "^11.0.0",
    "@tailwindcss/vite": "^4.1.14",
