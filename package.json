{
  "name": "praeventio-guard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "praeventio": "./scripts/cli/praeventio.mjs"
  },
  "scripts": {
    "cli": "node scripts/cli/praeventio.mjs",
    "dev": "tsx server.ts",
    "prebuild": "node scripts/download-mediapipe-models.mjs && node scripts/render-well-known.mjs && node scripts/prepackage-slm-models.mjs --model=qwen-2.5-0.5b",
    "build": "vite build",
    "prepackage:slm": "node scripts/prepackage-slm-models.mjs",
    "prepackage:slm:dry": "node scripts/prepackage-slm-models.mjs --dry-run",
    "prepackage:slm:force": "node scripts/prepackage-slm-models.mjs --force",
    "mcp:dev": "tsx bin/mcp-server.mjs",
    "mcp:start": "node bin/mcp-server.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "typecheck:ci": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc --noEmit",
    "lint": "eslint . && eslint firestore.rules",
    "lint:fix": "eslint . --fix && eslint firestore.rules --fix",
    "lint:rules": "eslint firestore.rules",
    "test": "vitest run",
    "test:ci": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --test-timeout=30000",
    "test:coverage": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --coverage --test-timeout=30000",
    "test:rules": "firebase emulators:exec --only firestore,storage --project praeventio-rules-test \"vitest run --config vitest.rules.config.ts\"",
    "smoke": "vitest run src/smoke.test.ts",
    "test:watch": "vitest",
    "verify:roles": "node scripts/verify-roles-sync.cjs",
    "security:review": "node scripts/security-review.cjs",
    "precommit:medical": "node scripts/precommit-medical-guard.cjs",
    "lint:conventions": "node scripts/check-convention-guard.cjs",
    "lint:i18n": "node scripts/validate-i18n.cjs",
    "lint:any": "node scripts/check-any-ratchet.cjs",
    "lint:connectivity": "node scripts/check-connectivity-ratchet.cjs",
    "lint:router-tests": "node scripts/check-router-test-ratchet.cjs",
    "gen:api-index": "node scripts/gen-api-index.cjs",
    "lint:api-index": "node scripts/gen-api-index.cjs --check",
    "test:medical-guard": "node --test src/__tests__/scripts/medicalGuard.test.cjs",
    "prepare": "husky install || true",
    "validate:env": "node scripts/validate-env.cjs",
    "validate:env:test": "node scripts/validate-env.cjs --mode test",
    "cap:sync": "npm run build && npx cap sync",
    "mesh:build": "cd packages/capacitor-mesh && npx tsc -p tsconfig.json",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "cap:build:android": "npm run build && npx cap sync android",
    "mobile:build:android": "npm run build && npx cap sync android && cd android && ./gradlew bundleRelease",
    "mobile:build:ios": "npm run build && npx cap sync ios && cd ios/App && pod install",
    "mobile:release:android": "bundle exec fastlane android internal",
    "mobile:release:ios": "cd ios/App && bundle exec fastlane ios testflight",
    "mobile:lint": "bash scripts/test-mobile-pipeline.sh",
    "start": "NODE_ENV=production tsx server.ts",
    "mutation": "stryker run stryker.config.json",
    "test:mutation": "stryker run stryker.config.json",
    "test:mutation:auth": "stryker run stryker.config.json --mutate=src/server/middleware/verifyAuth.ts",
    "test:mutation:slm": "stryker run stryker.config.json --mutate=src/services/slm/{orchestrator,offlineQueue,reconciliation}.ts",
    "test:mutation:ergonomics": "stryker run stryker.config.json --mutate=src/services/ergonomics/{rula,reba}.ts",
    "test:mutation:protocols": "stryker run stryker.config.json --mutate=src/services/protocols/{tmert,iper,prexor,planesi}.ts",
    "test:mutation:safety": "stryker run stryker.config.json --mutate=src/services/safety/{ergonomicAssessments,iperAssessments}.ts",
    "size": "size-limit",
    "lhci": "lhci autorun",
    "perf": "npm run build && size-limit && lhci autorun",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=true npx playwright test --project=chromium --project=mobile-android",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:full": "cross-env E2E_FULL_STACK=1 FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 GOOGLE_CLOUD_PROJECT=demo-test E2E_TEST_SECRET=e2e-test-secret-do-not-use-in-prod playwright test",
    "test:e2e:full:chromium": "cross-env E2E_FULL_STACK=1 FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 GOOGLE_CLOUD_PROJECT=demo-test E2E_TEST_SECRET=e2e-test-secret-do-not-use-in-prod playwright test --project=chromium",
    "test:e2e:emulator": "firebase emulators:start --only firestore --project demo-test",
    "loadtest:sos": "bash loadtest/run.sh",
    "canary:monitor": "node scripts/canary-monitor.cjs",
    "retro:weekly": "node scripts/retro-weekly.cjs"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor-community/bluetooth-le": "^8.1.3",
    "@capacitor-community/keep-awake": "^8.0.0",
