    "@kiwi-health/capacitor-health-connect": "^0.0.40",
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/hashes": "^2.2.0",
    "@perfood/capacitor-healthkit": "^1.3.2",
