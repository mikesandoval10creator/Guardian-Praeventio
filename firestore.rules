rules_version = '2';
// Role identifiers (admin/gerente/supervisor/medico_ocupacional/worker/etc.)
// MUST match src/types/roles.ts. The scripts/verify-roles-sync.cjs script
// is run in CI to enforce that this file and roles.ts agree.
//
// NOTE(billing): the `processed_webpay/{token_ws}` collection (added with
// the Webpay return-URL idempotency lock — server.ts /billing/webpay/return)
// is intentionally server-only. The default-deny rule below covers it; do
// NOT add a client-readable rule for it without a threat-model review
// (token_ws is short-lived but pairs with invoice ids — same sensitivity
// envelope as `invoices/{id}` and `processed_pubsub/{messageId}`).
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // DEFAULT DENY (Safety Net)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'gerente' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'gerente'
      );
    }

    function isSupervisor() {
      return isEmailVerified() && (
        request.auth.token.role in ['supervisor', 'prevencionista', 'director_obra', 'medico_ocupacional'] ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['supervisor', 'prevencionista', 'director_obra', 'medico_ocupacional']
      );
    }

    function isDoctor() {
      return isEmailVerified() && (
        request.auth.token.role == 'medico_ocupacional' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'medico_ocupacional'
      );
    }

    function isProjectCreator(projectId) {
      return isEmailVerified() && get(/databases/$(database)/documents/projects/$(projectId)).data.createdBy == request.auth.uid;
    }

    function isProjectMember(projectId) {
      return isEmailVerified() && (
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members ||
        isAdmin() ||
        isSupervisor() ||
        isProjectCreator(projectId)
      );
    }

    function isOwner(userId) {
      return isEmailVerified() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // ENTITY VALIDATION HELPERS (Blueprints)
    // ===============================================================
    
    function isValidRole(role) {
      return role in ['admin', 'gerente', 'supervisor', 'prevencionista', 'director_obra', 'medico_ocupacional', 'topografo', 'pintor', 'maquinista', 'electrico', 'soldador', 'mecanico', 'operario', 'contratista', 'worker'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().size() <= 20 &&
             data.uid == request.auth.uid && data.uid is string && data.uid.size() <= 128 &&
             data.email == request.auth.token.email && data.email is string && data.email.size() <= 256 &&
             isValidRole(data.role) &&
             data.createdAt == (resource == null ? request.time : resource.data.createdAt) &&
             (!('display_name' in data) || data.display_name is string) &&
             (!('photo_url' in data) || data.photo_url is string) &&
             (!('biometricKeys' in data) || data.biometricKeys is list);
    }

    function isValidNode(data) {
      return data.keys().hasAll(['type', 'title', 'description', 'createdAt', 'updatedAt', 'projectId', 'metadata']) &&
             data.keys().size() <= 15 &&
             data.type is string && data.type.size() > 0 && data.type.size() <= 50 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 50000 &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 50)) &&
             (!('connections' in data) || (data.connections is list && data.connections.size() <= 200)) &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             isValidId(data.projectId) &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'members', 'status', 'createdAt']) &&
             data.keys().size() <= 25 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.members is list && data.members.size() <= 500 &&
             data.status in ['active', 'completed', 'archived'] &&
             data.createdAt is string && data.createdAt.size() > 0;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['title', 'type', 'status', 'projectId', 'createdAt']) &&
             data.keys().size() <= 15 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.status in ['Pendiente', 'Cerrado', 'En Proceso'] &&
             data.type in ['Incidente', 'Auditoría', 'Observación'] &&
             isValidId(data.projectId) &&
             data.createdAt is string && data.createdAt.size() > 0;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['userId', 'content', 'type', 'createdAt']) &&
             data.keys().size() <= 20 &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.type in ['SafetyMoment', 'Tip', 'SuccessStory', 'Warning'] &&
             data.createdAt is string && data.createdAt.size() > 0;
    }

    // ===============================================================
    // COLLECTION MATCHING
    // ===============================================================

    function isWorkerRole(role) {
      return role in ['topografo', 'pintor', 'maquinista', 'electrico', 'soldador', 'mecanico', 'operario', 'contratista', 'worker'];
    }

    match /users/{userId} {
      allow read: if isValidId(userId) && (isOwner(userId) || isAdmin() || isSupervisor());
      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && (isWorkerRole(incoming().role) || isAdmin());
      allow update: if isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && (incoming().role == existing().role || isAdmin());
      allow delete: if isAdmin();
      
      // Strict privacy envelope for user's medical exams (Excludes Admin/Supervisor by default unless they are the Doctor)
      match /medical_exams/{examId} {
        allow read: if isOwner(userId) || isDoctor();
        allow write: if isDoctor();
      }
    }

    match /projects/{projectId} {
      allow read: if isValidId(projectId) && isProjectMember(projectId);
      allow create: if isEmailVerified() && isValidProject(incoming()) && incoming().createdBy == request.auth.uid;
      allow update: if isEmailVerified() && (isAdmin() || isSupervisor() || existing().createdBy == request.auth.uid) && isValidProject(incoming());
      allow delete: if isEmailVerified() && (isAdmin() || existing().createdBy == request.auth.uid);

      // Master Gate for sub-collections
      match /{subCollection=**}/{docId} {
        allow read: if isValidId(projectId) && isProjectMember(projectId);
      }

      match /emergency_messages/{messageId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId) && incoming().senderId == request.auth.uid;
      }

      match /emergency_checkins/{checkinId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId) && incoming().workerId == request.auth.uid;
      }

      match /attendance/{attendanceId} {
        allow create, update: if isValidId(projectId) && (isProjectMember(projectId) || isSupervisor() || isAdmin());
      }

      match /reports/{reportId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId) && isValidReport(incoming());
        allow update: if isValidId(projectId) && (isAdmin() || isSupervisor() || (existing().authorId == request.auth.uid && existing().status != 'Cerrado')) && isValidReport(incoming());
      }

      match /safety_posts/{postId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId) && isValidPost(incoming());
        allow update: if isValidId(projectId) && (isAdmin() || isSupervisor() || (existing().userId == request.auth.uid)) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'comments', 'updatedAt']) ||
          isValidPost(incoming())
        );
        allow delete: if isValidId(projectId) && (isAdmin() || isSupervisor() || (existing().userId == request.auth.uid));
      }
      
      // Strict constraints for other project data
      match /locations/{locationId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId) && incoming().userId == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      }
      
      // Admin/Creator-only write for remaining sub-collections
      match /events/{eventId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /emergency_protocols/{protocolId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /epp_items/{itemId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /epp_assignments/{assignmentId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /controls/{controlId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /materials/{materialId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /assets/{assetId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /workers/{workerId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
    }

    match /nodes/{nodeId} {
      allow read: if isEmailVerified() && (
        existing().isPublic == true ||
        isProjectMember(existing().projectId) ||
        existing().metadata.authorId == request.auth.uid ||
        isAdmin() ||
        isSupervisor()
      );
      allow create: if isEmailVerified() && isValidNode(incoming()) && incoming().metadata.authorId == request.auth.uid;
      allow update: if isEmailVerified() && isValidNode(incoming()) && (
        isAdmin() || 
        isSupervisor() || 
        existing().metadata.authorId == request.auth.uid ||
        incoming().diff(existing()).affectedKeys().hasOnly(['connections', 'updatedAt'])
      );
      allow delete: if isAdmin() || isSupervisor();
    }

    match /user_stats/{userId} {
      allow read: if isValidId(userId) && (isOwner(userId) || isAdmin() || isSupervisor());
      allow update: if isValidId(userId) && isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['points', 'completedTrainings', 'safetyPosts', 'medals', 'loginStreak', 'lastLogin', 'updatedAt']);
      allow create: if isValidId(userId) && isOwner(userId) && incoming().points == 0;
      allow delete: if isAdmin();
    }

    match /telemetry_events/{eventId} {
      allow read: if isAdmin() || isSupervisor();
      allow create: if isEmailVerified();
    }

    match /training/{sessionId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() || 
        (existing().projectId != null && isProjectMember(existing().projectId))
      );
      allow write: if isAdmin() || isSupervisor();
    }

    match /safety_solutions/{solutionId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() || 
        (existing().projectId != null && isProjectMember(existing().projectId))
      );
      allow write: if isAdmin() || isSupervisor();
    }

    match /normatives/{normativeId} {
      allow read: if isEmailVerified(); // Note: Global normative data may be public for verified users
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      // Audit trail is server-only: any client-side `create` is a self-fabrication
      // vector (a worker could log a fake "I revoked admin X" entry attributing
      // it to themselves and pollute the immutable audit history). All audit
      // writes happen via the Admin SDK from server.ts (e.g. /api/admin/set-role,
      // /api/admin/revoke-access), which bypasses these rules.
      // Client-side denial is exercised by src/rules-tests/firestore.rules.test.ts
      // (covers unauthenticated/worker/supervisor/gerente create + immutability).
      allow read: if isAdmin();
      allow create: if false; // server-only via Admin SDK
      allow update, delete: if false; // Immutable audit trail
    }

    match /vector_store/{docId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() || 
        (existing().projectId != null && isProjectMember(existing().projectId))
      );
      allow write: if isAdmin();
    }
    
    match /transactions/{transactionId} {
      allow read: if isOwner(get(/databases/$(database)/documents/transactions/$(transactionId)).data.userId) || isAdmin();
      allow write: if false; // Only server-side via Admin SDK
    }

    // Invitations — written by server (Admin SDK), read by invited user to see pending invites
    match /invitations/{inviteId} {
      allow read: if isEmailVerified() && (
        resource.data.invitedEmail == request.auth.token.email ||
        isAdmin() ||
        isProjectCreator(resource.data.projectId)
      );
      allow write: if false; // Only server-side via Admin SDK
    }

    // Gamification content — global content written by admins, readable by all authenticated users
    match /gamification_content/{contentId} {
      allow read: if isEmailVerified();
      allow write: if isAdmin();
    }

    // Community glossary — global shared knowledge, writable only by admins/supervisors
    match /community_glossary/{termId} {
      allow read: if isEmailVerified();
      allow write: if isAdmin() || isSupervisor();
    }

    // Blueprints — project-scoped floor plans and technical drawings
    match /blueprints/{blueprintId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() ||
        isProjectMember(resource.data.projectId)
      );
      allow create: if isEmailVerified() && isProjectMember(incoming().projectId);
      allow update: if isEmailVerified() && (isAdmin() || isSupervisor() || isProjectCreator(resource.data.projectId));
      allow delete: if isAdmin() || isSupervisor() || isProjectCreator(resource.data.projectId);
    }

    // OAuth tokens — server-only via Admin SDK. Never readable from client.
    // Stored at oauth_tokens/{uid}_{provider} (e.g. abc123_google, abc123_google-drive).
    match /oauth_tokens/{tokenId} {
      allow read, write: if false;
    }

    // Global templates — seed data, read-only for all authenticated users
    match /global_templates/{templateId} {
      allow read: if isEmailVerified();
      allow write: if isAdmin();
    }

    // Project documents — uploaded files scoped to a project
    match /project_documents/{docId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() ||
        isProjectMember(resource.data.projectId)
      );
      allow create: if isEmailVerified() && isProjectMember(incoming().projectId);
      allow delete: if isAdmin() || isSupervisor() || isProjectCreator(resource.data.projectId);
    }

    // AI feedback — users can submit vote on their own session; admins can read all
    match /ai_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isEmailVerified() && (
        incoming().userId == request.auth.uid || incoming().userId == null
      );
      allow update, delete: if false;
    }

    // Wisdom capsules — geo-activated knowledge attached to machines/locations
    match /wisdomCapsules/{capsuleId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && (isAdmin() || isSupervisor());
      allow update: if isEmailVerified() && (isAdmin() || isSupervisor());
      allow delete: if isAdmin();
    }
  }
}
