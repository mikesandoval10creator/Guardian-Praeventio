rules_version = '2';
// Role identifiers (admin/gerente/supervisor/medico_ocupacional/worker/etc.)
// MUST match src/types/roles.ts. The scripts/verify-roles-sync.cjs script
// is run in CI to enforce that this file and roles.ts agree.
//
// NOTE(billing): the `processed_webpay/{token_ws}` collection (added with
// the Webpay return-URL idempotency lock — server.ts /billing/webpay/return)
// is intentionally server-only. The default-deny rule below covers it; do
// NOT add a client-readable rule for it without a threat-model review
// (token_ws is short-lived but pairs with invoice ids — same sensitivity
// envelope as `invoices/{id}` and `processed_pubsub/{messageId}`).
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // DEFAULT DENY (Safety Net)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'gerente' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'gerente'
      );
    }

    function isSupervisor() {
      return isEmailVerified() && (
        request.auth.token.role in ['supervisor', 'prevencionista', 'director_obra', 'medico_ocupacional'] ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['supervisor', 'prevencionista', 'director_obra', 'medico_ocupacional']
      );
    }

    // Fase D.4 — Tenant-scoped supervisor.
    //
    // The global isSupervisor() above grants role-wide access across the
    // whole product. For collections that are partitioned by tenant
    // (e.g. /tenants/{tid}/projects/...) we need a stricter check: the
    // user must (a) have a supervisor-tier role AND (b) carry an active
    // claim binding them to the specific tenant.
    //
    // The expected claim shape — written by trusted server code only —
    // is one of:
    //
    //   token.tenantId == <tenantId>                                (single-tenant claim)
    //   token.tenants is map and token.tenants[tenantId] in [roles] (multi-tenant claim)
    //
    // The second form lets the same user act as supervisor in tenant A
    // and as worker in tenant B without re-issuing tokens.
    function hasSupervisorTierRole() {
      return isEmailVerified() && (
        request.auth.token.role in ['supervisor', 'prevencionista', 'director_obra', 'medico_ocupacional', 'gerente', 'admin']
      );
    }

    function isMemberOfTenant(tenantId) {
      return isEmailVerified() && tenantId is string && tenantId.size() > 0 && (
        // Single-tenant claim — token.tenantId points at exactly this tenant.
        (request.auth.token.tenantId is string && request.auth.token.tenantId == tenantId) ||
        // Multi-tenant claim — token.tenants is a map with the tenant id as key.
        ('tenants' in request.auth.token && request.auth.token.tenants[tenantId] is string)
      );
    }

    function isSupervisorOfTenant(tenantId) {
      // 2026-05-15 fix: el chequeo de rol depende del shape del claim.
      // Para single-tenant claim (`token.tenantId` igual al tenant) el
      // rol GLOBAL del token debe ser supervisor-tier. Para
      // multi-tenant claim (`token.tenants[tid]`) lo que manda es el
      // rol POR-TENANT — un usuario global=worker pero tenants.A=supervisor
      // DEBE poder leer /tenants/A/supervisor_only/*. La versión vieja
      // hacía AND con `hasSupervisorTierRole()` (global) y bloqueaba ese
      // caso erróneamente.
      return isEmailVerified() && (
        // Single-tenant claim: global role tiene que ser supervisor-tier.
        (
          request.auth.token.tenantId is string &&
          request.auth.token.tenantId == tenantId &&
          hasSupervisorTierRole()
        ) ||
        // Multi-tenant claim: el rol POR-TENANT tiene que ser supervisor-tier.
        // Workers/operarios con membership en este tenant son rechazados
        // aquí incluso si tienen claim supervisor en otro tenant — el rol
        // global queda fuera de la decisión porque cada tenant es soberano.
        (
          'tenants' in request.auth.token &&
          request.auth.token.tenants[tenantId] is string &&
          request.auth.token.tenants[tenantId] in ['supervisor', 'prevencionista', 'director_obra', 'medico_ocupacional', 'gerente', 'admin']
        )
      );
    }

    function isDoctor() {
      return isEmailVerified() && (
        request.auth.token.role == 'medico_ocupacional' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'medico_ocupacional'
      );
    }

    function isProjectCreator(projectId) {
      return isEmailVerified() && get(/databases/$(database)/documents/projects/$(projectId)).data.createdBy == request.auth.uid;
    }

    function isProjectMember(projectId) {
      return isEmailVerified() && (
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members ||
        isAdmin() ||
        isSupervisor() ||
        isProjectCreator(projectId)
      );
    }

    function isOwner(userId) {
      return isEmailVerified() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // A `nodes` doc whose metadata carries a worker's raw RUT (Chilean national
    // ID) — written by the DS 67 (INCIDENT) and DS 109 (MEDICINE) legal-form
    // modals (src/components/medicine/Ds67Modal.tsx, Ds109Modal.tsx). The RUT is
    // medical/injury PII and must NOT be readable by every project member; it is
    // restricted to the node author + admin/supervisor (the staff who file the
    // DIAT/DIEP to the mutualidad). Null-safe: false when metadata or the key is
    // absent, so ordinary (non-PII) nodes keep member-readability.
    function nodeHasWorkerRut(data) {
      return 'metadata' in data
        && data.metadata is map
        && 'workerRut' in data.metadata;
    }

    // ===============================================================
    // ENTITY VALIDATION HELPERS (Blueprints)
    // ===============================================================
    
    function isValidRole(role) {
      return role in ['admin', 'gerente', 'supervisor', 'prevencionista', 'director_obra', 'medico_ocupacional', 'topografo', 'pintor', 'maquinista', 'electrico', 'soldador', 'mecanico', 'operario', 'contratista', 'worker'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().size() <= 20 &&
             data.uid == request.auth.uid && data.uid is string && data.uid.size() <= 128 &&
             data.email == request.auth.token.email && data.email is string && data.email.size() <= 256 &&
             isValidRole(data.role) &&
             data.createdAt == (resource == null ? request.time : resource.data.createdAt) &&
             (!('display_name' in data) || data.display_name is string) &&
             (!('photo_url' in data) || data.photo_url is string) &&
             (!('biometricKeys' in data) || data.biometricKeys is list);
    }

    function isValidNode(data) {
      return data.keys().hasAll(['type', 'title', 'description', 'createdAt', 'updatedAt', 'projectId', 'metadata']) &&
             data.keys().size() <= 15 &&
             data.type is string && data.type.size() > 0 && data.type.size() <= 50 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 50000 &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 50)) &&
             (!('connections' in data) || (data.connections is list && data.connections.size() <= 200)) &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             isValidId(data.projectId) &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'members', 'status', 'createdAt']) &&
             data.keys().hasOnly([
               // Core schema (matches Project interface in src/contexts/ProjectContext.tsx)
               'name', 'description', 'location', 'coordinates',
               'industry', 'status', 'startDate', 'endDate', 'clientName',
               'riskLevel', 'workersCount', 'members',
               'createdAt', 'createdBy', 'updatedAt', 'isPendingSync',
               // Legal / SUSESO
               'companyName', 'companyRut', 'companyAddress', 'mutualidad',
               // Emergency + tracking
               'phone', 'shiftStart', 'shiftEnd', 'trackCommute', 'settings',
               // Emergency declaration state (B1) — written by EmergencyCheckIn
               // toggleEmergency via setDoc(merge). Without these in the
               // allowlist, declaring an emergency was silently denied.
               'isEmergencyActive', 'activeEmergencyProtocol', 'emergencyStartTime',
               // Future-proof slots used by some integrations
               'ownerUid', 'ownerEmail', 'organizationId', 'erpId',
               'tags', 'metadata', 'invitedEmails', 'photos',
               'archived', 'archivedAt', 'archivedBy',
               'safetyScore', 'lastIncidentAt'
             ]) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.members is list && data.members.size() <= 500 &&
             data.status in ['active', 'completed', 'archived'] &&
             data.createdAt is string && data.createdAt.size() > 0;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['title', 'type', 'status', 'projectId', 'createdAt']) &&
             data.keys().size() <= 15 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.status in ['Pendiente', 'Cerrado', 'En Proceso'] &&
             data.type in ['Incidente', 'Auditoría', 'Observación'] &&
             isValidId(data.projectId) &&
             data.createdAt is string && data.createdAt.size() > 0;
    }

    // #4 — public DEA (AED) registry schema. Only public-good fields; coordinates
    // are REQUIRED (the whole point is a geolocated finder). No PII, no
    // responsible person, no inspection dates.
    function isValidDeaLocation(data) {
      return data.keys().hasOnly(['location', 'coordinates', 'status', 'projectId', 'updatedAt']) &&
             data.keys().hasAll(['location', 'coordinates', 'status', 'projectId']) &&
             data.location is string && data.location.size() > 0 && data.location.size() <= 200 &&
             data.coordinates is map &&
             data.coordinates.lat is number && data.coordinates.lng is number &&
             data.status in ['operational', 'warning', 'critical'] &&
             isValidId(data.projectId);
    }

    // CPHS committee minute (Comité Paritario acta, DS54). Fixed client schema
    // written ONLY by the ComiteParitario page: { fecha, tipo, asistentes[],
    // acuerdos[], createdAt }. `hasOnly` blocks any extra top-level field — a
    // compliance/legal record must not become a sink for smuggled PII.
    function isValidComiteActa(data) {
      return data.keys().hasOnly(['fecha', 'tipo', 'asistentes', 'acuerdos', 'createdAt']) &&
             data.keys().hasAll(['fecha', 'tipo', 'asistentes', 'acuerdos', 'createdAt']) &&
             data.fecha is string && data.fecha.size() > 0 && data.fecha.size() <= 40 &&
             data.tipo is string && data.tipo.size() > 0 && data.tipo.size() <= 60 &&
             data.asistentes is list &&
             data.acuerdos is list &&
             data.createdAt is string && data.createdAt.size() > 0;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['userId', 'content', 'type', 'createdAt']) &&
             data.keys().size() <= 20 &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.type in ['SafetyMoment', 'Tip', 'SuccessStory', 'Warning'] &&
             data.createdAt is string && data.createdAt.size() > 0;
    }

    // ===============================================================
    // COLLECTION MATCHING
    // ===============================================================

    function isWorkerRole(role) {
      return role in ['topografo', 'pintor', 'maquinista', 'electrico', 'soldador', 'mecanico', 'operario', 'contratista', 'worker'];
    }

    match /users/{userId} {
      allow read: if isValidId(userId) && (isOwner(userId) || isAdmin() || isSupervisor());
      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && (isWorkerRole(incoming().role) || isAdmin());
      // Round 22 audit fix CRITICAL #5 (DT-05): deny client write of
      // subscription.* fields. Plan upgrades MUST go through
      // /api/subscription/upgrade (verified payment) or via Webpay/MP
      // IPN handlers (Admin SDK bypasses these rules). Without this
      // check any authenticated user could self-promote to Ilimitado.
      allow update: if isValidId(userId) && isOwner(userId) && isValidUser(incoming())
                    && (incoming().role == existing().role || isAdmin())
                    && !incoming().diff(existing()).affectedKeys().hasAny([
                         'subscriptionPlan',
                         'subscription',
                       ]);
      allow delete: if isAdmin();
      
      // Strict privacy envelope for user's medical exams (Excludes Admin/Supervisor by default unless they are the Doctor)
      match /medical_exams/{examId} {
        allow read: if isOwner(userId) || isDoctor();
        allow write: if isDoctor();
      }

      // Morning wellness self-check (MorningRoutine, hygiene). Private to the
      // worker and the occupational-health doctor; the worker writes their own
      // check-in; the wellness history is never deleted.
      match /morning_checkins/{date} {
        allow read: if isOwner(userId) || isDoctor();
        allow create, update: if isOwner(userId);
        allow delete: if false;
      }

      // Personal focus/deep-work blocks (focusBlocks.ts →
      // users/{uid}/focus_blocks/{id}). Strictly private to the worker — they
      // create, read, and reschedule their own blocks. Was default-denied →
      // createFocusBlock() and listUpcoming() both failed in production.
      match /focus_blocks/{blockId} {
        allow read, write: if isOwner(userId);
      }

      // Portable-curriculum awards/badges (PortableCurriculum.tsx reads
      // users/{uid}/awards). The worker reads their OWN earned badges; awards
      // are MINTED server-side (Admin SDK bypasses these rules) so the client
      // can never self-award. Was default-denied → the curriculum showed no badges.
      match /awards/{awardId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // ── HealthVault medical records (Sprint 25/26 Bucket VV, ADR 0012) ──
      // `users/{uid}/health_vault/{recordId}` holds the worker's medical
      // records (HealthRecord — lab results, imaging, audiometry, etc.;
      // src/services/health/vaultRecord.ts). HIGHEST-privacy data + the
      // file blobs are KMS-envelope-encrypted via `fileEncryptionKeyId`.
      // Written ONLY by trusted server code (Admin SDK bypasses these rules)
      // and NEVER read by the client SDK — the only read path is the
      // server-side doctor `/api/health-vault/view/...` endpoint gated on a
      // one-time share secret. So the client gets NOTHING: read+write denied.
      match /health_vault/{recordId} {
        allow read, write: if false;
      }

      // HealthVault share tokens (`users/{uid}/health_vault_shares/{tokenId}`,
      // VaultShareToken — src/services/health/vaultShare.ts). Created /
      // consumed / revoked ONLY by trusted server code (Admin SDK):
      //   POST /api/health-vault/share            (create)
      //   GET  /api/health-vault/view/:id/:secret (consume — public, doctor)
      //   POST /api/health-vault/share/:id/revoke (revoke)
      // The worker reads their OWN active-shares list with the client SDK
      // (src/pages/HealthVaultShare.tsx:60) to see consume counts / expiry /
      // revoke. Read = owner OR occupational doctor OR admin, mirroring the
      // medical_exams privacy envelope. The doc stores only `tokenHash`
      // (SHA-256) + `tokenPrefix`, never the raw secret (vaultShare.ts:71-75),
      // so a read leaks no usable access token. ALL client writes denied →
      // tokens are immutable + unforgeable; only the server mutates state.
      match /health_vault_shares/{tokenId} {
        allow read: if isOwner(userId) || isDoctor() || isAdmin();
        allow write: if false;
      }
    }

    match /projects/{projectId} {
      allow read: if isValidId(projectId) && isProjectMember(projectId);
      allow create: if isEmailVerified() && isValidProject(incoming()) && incoming().createdBy == request.auth.uid;
      allow update: if isEmailVerified() && (isAdmin() || isSupervisor() || existing().createdBy == request.auth.uid) && isValidProject(incoming());
      allow delete: if isEmailVerified() && (isAdmin() || existing().createdBy == request.auth.uid);

      // Master Gate for sub-collections
      match /{subCollection=**}/{docId} {
        allow read: if isValidId(projectId) && isProjectMember(projectId);
      }

      match /emergency_messages/{messageId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId) && incoming().senderId == request.auth.uid;
      }

      match /emergency_checkins/{checkinId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId) && incoming().workerId == request.auth.uid;
      }

      match /attendance/{attendanceId} {
        allow create, update: if isValidId(projectId) && (isProjectMember(projectId) || isSupervisor() || isAdmin());
      }

      match /reports/{reportId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId) && isValidReport(incoming());
        allow update: if isValidId(projectId) && (isAdmin() || isSupervisor() || (existing().authorId == request.auth.uid && existing().status != 'Cerrado')) && isValidReport(incoming());
      }

      match /safety_posts/{postId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId) && isValidPost(incoming());
        allow update: if isValidId(projectId) && (isAdmin() || isSupervisor() || (existing().userId == request.auth.uid)) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'comments', 'updatedAt']) ||
          isValidPost(incoming())
        );
        allow delete: if isValidId(projectId) && (isAdmin() || isSupervisor() || (existing().userId == request.auth.uid));
      }

      // Safety-critical collections — strict read for project members,
      // create by any project member (sensor-driven), updates restricted.
      match /mandown_events/{eventId} {
        allow read: if isValidId(projectId) && isProjectMember(projectId);
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().status in ['pending', 'active']
          && incoming().workerId == request.auth.uid;
        // Acknowledgement: any supervisor/admin/member can ack; only ack fields mutable
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'acknowledgedBy', 'acknowledgedByName', 'acknowledgedAt', 'resolvedAt', 'resolvedBy', 'updatedAt']);
        allow delete: if false;
      }

      match /zone_violations/{violationId} {
        allow read: if isValidId(projectId) && isProjectMember(projectId);
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().workerId == request.auth.uid;
        allow update, delete: if false;
      }

      // SystemEngine bus (ADR-0013 Flow Infinito) — A4 re-scope 2026-06.
      // The client EventLog (src/services/systemEngine/eventLog.ts) writes
      // typed events here via the CLIENT SDK; useSystemEvent onSnapshots the
      // same path. The bus previously targeted tenants/{tid}/system_events,
      // which was default-denied (tenants catch-all `create:false`) AND keyed
      // by a tenant id no install ever assigned — every cross-device emit was
      // PERMISSION_DENIED. The PROJECT is the real tenancy unit, so the rule
      // mirrors the zone_violations sibling: member read + member create with
      // envelope schema validation, path-bound projectId (no cross-project
      // inject) and emitter anti-spoof (`actorUid` must be the caller or
      // null). Events are IMMUTABLE — update/delete denied for everyone; the
      // server-side collectionGroup trigger mirrors each event to audit_logs.
      match /system_events/{eventId} {
        allow read: if isValidId(projectId) && isProjectMember(projectId);
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().keys().hasAll(['id', 'tenantId', 'projectId', 'ts', 'idempotencyKey', 'type', 'payload'])
          && incoming().id is string && incoming().id == eventId
          && incoming().tenantId is string
          && incoming().projectId == projectId
          && incoming().ts is number
          && incoming().idempotencyKey is string
          && incoming().type is string
          && incoming().payload is map
          && (!('actorUid' in incoming()) || incoming().actorUid == null || incoming().actorUid == request.auth.uid);
        allow update, delete: if false;
      }

      // Seismic auto-detection telemetry — A4 follow-up re-scope 2026-06.
      // src/components/shared/EmergencyOverlay.tsx (SismicAutoOverlay) logs one
      // row per on-device sismo trigger via the CLIENT SDK. It previously wrote
      // tenants/{tid}/seismic_events keyed by `window.__GP_TENANT_ID__ ||
      // 'default'` — a global no install ever assigns — behind
      // isMemberOfTenant() claims no flow mints, so every production write was
      // PERMISSION_DENIED (the same double-death as system_events, PR #847).
      // Re-scoped to the PROJECT (the real tenancy unit). Life-safety telemetry
      // is FREE on every tier (ADR 0021): member read + member create with
      // schema validation, path-bound projectId (no cross-project inject),
      // immutable once written (the accelerometer log is evidence).
      match /seismic_events/{eventId} {
        allow read: if isValidId(projectId) && isProjectMember(projectId);
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().keys().hasAll(['detectedAt', 'peakG', 'projectId'])
          && incoming().detectedAt is string
          && incoming().peakG is number
          && incoming().projectId == projectId;
        allow update, delete: if false;
      }

      // Digital Twin reconstruction jobs — server writes only, members read.
      // NOTE: this collection has NO writers in the codebase (phantom/legacy).
      // The REAL on-device photogrammetry job store writes `reconstruction_jobs`
      // (below), NOT this path.
      match /digital_twin_jobs/{jobId} {
        allow read: if isValidId(projectId) && isProjectMember(projectId);
        allow write: if false;
      }

      // Photogrammetry reconstruction jobs (on-device pipeline, CLIENT SDK via
      // src/services/digitalTwin/photogrammetry/reconstructionJobStore.ts →
      // projects/{pid}/reconstruction_jobs/{jobId}). The worker running the scan
      // creates the job and persists progress/completion/failure client-side, so
      // create/update are member-gated (NOT server-only like digital_twin_jobs).
      // Was DEFAULT-DENIED → createReconstructionJob() failed and the job never
      // even started (it is written BEFORE the GLB upload). Mirrors placed_objects:
      // member create/update, admin/supervisor delete (a job record is part of the
      // site's safety/inspection trail — only a privileged role may erase one).
      match /reconstruction_jobs/{jobId} {
        allow read: if isValidId(projectId) && isProjectMember(projectId);
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }
      
      // Strict constraints for other project data
      match /locations/{locationId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId) && incoming().userId == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      }
      
      // Admin/Creator-only write for remaining sub-collections
      match /events/{eventId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /emergency_protocols/{protocolId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /epp_items/{itemId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /epp_assignments/{assignmentId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /controls/{controlId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /materials/{materialId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /assets/{assetId} { allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId); }
      match /workers/{workerId} {
        allow write: if isAdmin() || isSupervisor() || isProjectCreator(projectId);
        // Worker documents (certs, contracts, EPP records, SUSESO docs) attached
        // via DocsModal (client SDK addDoc/onSnapshot/deleteDoc). The schema
        // carries `workerId` (the worker doc id, NOT a caller uid) → there is no
        // anti-spoof field to bind, so create/update is plain member-gated like
        // the sibling /documents and /findings rules. Read is already granted to
        // project members by the sub-collection Master Gate (line ~329), so only
        // create/update/delete need rules here. Deleting a worker document
        // (compliance/legal trail) is restricted to admin/supervisor. Previously
        // the nested `match /workers/{workerId}` declared NO documents sub-match
        // → the worker Documentación feature was default-denied in production.
        match /documents/{documentId} {
          allow create, update: if isValidId(projectId) && isProjectMember(projectId);
          allow delete: if isAdmin() || isSupervisor();
        }
      }

      // Emergency events — members create, supervisors/admins update status
      match /emergency_events/{eventId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().status in ['active', 'pending']
          && incoming().triggeredBy == request.auth.uid;
        allow update: if isValidId(projectId) && (isAdmin() || isSupervisor())
          && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'resolvedAt', 'resolvedBy', 'updatedAt']);
        allow delete: if false;
      }

      // ── Emergency orchestration + ops sub-collections (§365 root-cause) ──
      // The seismic-orchestration dashboard (src/pages/EmergenciaAvanzada.tsx)
      // and the AI plan / EPP / training / notification writers persist to
      // these project sub-collections. The Master Gate (line ~342) grants member
      // READ but NO write, so every write was default-denied → the live
      // emergency channel, the worker safety roll-call, AI emergency plans,
      // in-app notifications, EPP verifications and training assignments all
      // silently failed in production. Life-safety features are FREE on every
      // tier (ADR 0021) → member-gated, NEVER tier-gated. These payloads carry
      // no caller-uid anti-spoof field (sender/workerId are display ids, not
      // request.auth.uid), so they follow the plain member-gate pattern of the
      // sibling /documents and /findings rules.

      // Live emergency chat — append-only; any member posts, nobody edits.
      match /emergency_chat/{messageId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId);
        allow update, delete: if false;
      }

      // Worker safety roll-call (docId == workerId). During an active emergency
      // a member confirms their own status AND a supervisor marks others, so
      // create/update are member-gated (not uid-bound). Never deleted.
      match /emergency_safety/{workerId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if false;
      }

      // AI-generated emergency plans (EmergencyPlanGenerator). Any member may
      // generate; only admin/supervisor revise or remove a saved plan.
      match /emergency_plans/{planId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId);
        allow update, delete: if isAdmin() || isSupervisor();
      }

      // In-app notifications (orphan-risk/worker detection — Zettelkasten hook).
      // Members create + mark-read; deletion restricted to admin/supervisor.
      match /notifications/{notificationId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }

      // AI EPP verification records (EPPVerificationModal). Compliance trail —
      // members create, immutable thereafter, admin/supervisor may purge.
      match /epp_verifications/{verificationId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId);
        allow update: if false;
        allow delete: if isAdmin() || isSupervisor();
      }

      // Training assignments (TrainingRecommendations). Members create + update
      // status (assigned→done); admin/supervisor may delete.
      match /trainings/{trainingId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }

      // AI safety capsules (Training.tsx → projects/{pid}/training_capsules).
      // Any member generates their own capsule; admin/supervisor may revise/purge.
      // Was default-denied by the Master Gate (read-only) → the AI capsule never
      // persisted (SloErrorBudget §365-class gap).
      match /training_capsules/{capsuleId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId);
        allow update, delete: if isAdmin() || isSupervisor();
      }

      // Auto-scheduled calendar events (useAutoCalendarEvents → monthly inspection
      // reminders). Members create/update; admin/supervisor may delete. (The
      // top-level `calendar_events` collection, written by the digital-twin
      // lifecycle, has its own projectId-gated rule below.)
      match /calendar_events/{eventId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }

      // Brigade config — supervisors/admins write assignment docs
      match /brigade_config/{docId} {
        allow write: if isValidId(projectId) && (isAdmin() || isSupervisor() || isProjectCreator(projectId));
      }

      // ISO management sub-collections — supervisors/admins/creator write
      match /iso_documents/{docId} {
        allow create: if isValidId(projectId) && (isAdmin() || isSupervisor() || isProjectCreator(projectId));
        allow update, delete: if isValidId(projectId) && (isAdmin() || isSupervisor() || isProjectCreator(projectId));
      }
      match /iso_improvements/{docId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId);
        allow update: if isValidId(projectId) && (isAdmin() || isSupervisor() || existing().createdBy == request.auth.uid);
        allow delete: if isAdmin() || isSupervisor();
      }

      // Morning check-ins — each member creates/updates their own record
      match /morning_checkins/{checkinId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().userId == request.auth.uid;
        allow update: if isValidId(projectId) && existing().userId == request.auth.uid
          && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'answers', 'completed']);
        allow delete: if false;
      }

      // ===============================================================
      // 2026-06-01 — Sprint-K client-SDK stores (createProjectScopedStore).
      //
      // These 14 collections use the Firebase CLIENT SDK (setDoc/updateDoc to
      // projects/{pid}/<coll>) but had NO write rule, so the master-gate
      // `{subCollection=**}` granted read-only and every client save() was
      // default-denied in production (masked by the open `firestore.test.rules`
      // used by the firestore-stores CI job). See TODO.md §17 "HALLAZGO CRÍTICO".
      //
      // Access model (CONSERVATIVE — REVIEW per collection, dahosandoval@):
      //   • create: project member; anti-spoof on the creator-uid field where
      //     the schema has one (incoming().<field> == caller).
      //   • update: project member; the creator-uid field is immutable; signed
      //     records (`signedAt`) are append-only.
      //   • delete: false for compliance records (legal evidence); admin/
      //     supervisor for operational ones.
      //   • read is already granted by the {subCollection=**} master-gate.
      // `sample_live` is intentionally NOT here — it is a test-only collection.
      // ===============================================================

      // -- Compliance / append-only (no client delete) ----------------
      // Stoppage (paralización DS): state machine declare→resume/cancel, so
      // updates are allowed but the declarer is immutable and it can't be deleted.
      match /stoppages/{stoppageId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().declaredByUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().declaredByUid == existing().declaredByUid;
        allow delete: if false;
      }
      match /operational_changes/{changeId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().declaredByUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().declaredByUid == existing().declaredByUid;
        allow delete: if false;
      }
      match /root_causes/{rcId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().analyzedByUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().analyzedByUid == existing().analyzedByUid;
        allow delete: if false;
      }
      // 5-Why root-cause analyses persisted CLIENT-SIDE by rootCauseStore.ts
      // (RootCauseInvestigation.tsx → projects/{pid}/root_cause_analyses/{incidentId}).
      // This is a DIFFERENT collection from `root_causes` above (the generic
      // createProjectScopedStore factory) — the page writes here, so without
      // this rule the {subCollection=**} master-gate granted read-only and every
      // client save() was default-denied in production. Anti-spoof on the real
      // schema field `analyzedByUid` (rootCauseClassifier.ts buildAnalysis()):
      // the supervisor who closes the analysis signs it with their own UID and
      // it stays immutable on update. Compliance record (no client delete).
      match /root_cause_analyses/{analysisId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().analyzedByUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().analyzedByUid == existing().analyzedByUid;
        allow delete: if false;
      }
      // DEA — desfibriladores externos (Ley 21.156). Equipo que salva vidas:
      // cualquier miembro del proyecto registra/actualiza un DEA (anti-spoof en
      // createdBy), las inspecciones son un registro INMUTABLE de cumplimiento,
      // y borrar un DEA queda restringido a admin/supervisor. Lectura cubierta
      // por el master-gate de subcolecciones (isProjectMember).
      match /deas/{deaId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().createdBy == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().createdBy == existing().createdBy;
        allow delete: if isAdmin() || isSupervisor();
        match /inspections/{inspectionId} {
          allow create: if isValidId(projectId) && isProjectMember(projectId)
            && incoming().performedByUid == request.auth.uid;
          // Registro inmutable de cumplimiento (Ley 21.156).
          allow update, delete: if false;
        }
      }
      // Clinical alerts (VitalityMonitor — NON-diagnostic safety recommendations
      // post ADR-0012 reconversion: signal + recommendation, no CIE-10). Written
      // by the worker's device; createdBy must be the caller and is immutable.
      // Deleting a safety alert is restricted to admin/supervisor. Read via the
      // sub-collection master-gate. Previously had NO write rule → default-denied.
      match /clinical_alerts/{alertId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().createdBy == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().createdBy == existing().createdBy;
        allow delete: if isAdmin() || isSupervisor();
      }
      // Project documents (reports, emergency plans, EPP & SUSESO docs — many
      // client-SDK writers with varied schemas). Member-gated create/update;
      // deleting a project document (compliance/legal trail) is restricted to
      // admin/supervisor. Read via the sub-collection master-gate. Previously had
      // NO write rule → the Documents feature was default-denied in production.
      match /documents/{documentId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }
      // CPHS committee minutes (Comité Paritario actas, DS54). Written by the
      // ComiteParitario page (client SDK): create the acta, then append acuerdos
      // via arrayUnion / replace the acuerdos array on a status change. No
      // creator-uid field → member-gated create/update, but schema-validated
      // (legal compliance record — no PII smuggling) and the creation stamp +
      // meeting date are immutable once set. Deleting a CPHS minute (legal trail)
      // is restricted to admin/supervisor. Previously had NO write rule → the
      // Comité Paritario feature was default-denied in production.
      match /comite_actas/{actaId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && isValidComiteActa(incoming());
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && isValidComiteActa(incoming())
          && incoming().createdAt == existing().createdAt
          && incoming().fecha == existing().fecha;
        allow delete: if isAdmin() || isSupervisor();
      }
      // Bio-analysis / inspection findings (BioAnalysis + Hallazgos, client SDK).
      // The schema carries `reportedBy` (display name, not a uid) → member-gated
      // create/update; deleting a safety finding is restricted to admin/supervisor.
      match /findings/{findingId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }
      // Digital-twin placed objects (hazards/equipment placed in the 3D twin,
      // placedObjectsStore client SDK). No creator-uid field → member-gated;
      // deleting a placed safety object is restricted to admin/supervisor.
      match /placed_objects/{objectId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }
      // Personalized AI safety plans (PersonalizedSafetyPlan, client SDK). The
      // schema has no creator-uid field → member-gated; admin/supervisor delete.
      match /personalized_plans/{planId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }
      // Driving incidents (SafeDriving). D2 slice 2: reports are created
      // exclusively by the audited server endpoint
      // POST /api/sprint-k/:projectId/driving/incidents (Admin SDK bypasses
      // rules; reportedByUid is stamped from the verified token). No client
      // code path writes here anymore (SafeDriving.tsx now POSTs; the offline
      // sync queues — matrixSyncManager/`nodes`, inspectionOutbox, sosOutbox —
      // never replay this collection), so client create/update is CLOSED.
      // Delete stays admin/supervisor for moderation parity with siblings.
      match /driving_incidents/{incidentId} {
        allow create, update: if false;
        allow delete: if isAdmin() || isSupervisor();
      }
      // Read receipts (DS44/RIOHS) — legal acknowledgement that a worker read a
      // document. projects/{pid}/read_receipts/{documentId__workerUid}. The worker
      // writes ONLY their own receipt (workerUid == caller, immutable); the acuse
      // is never deleted. Read via the sub-collection master-gate.
      match /read_receipts/{receiptId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().workerUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().workerUid == existing().workerUid
          && existing().workerUid == request.auth.uid;
        allow delete: if false;
      }
      // Critical-control validations (DS44 — controles críticos de seguridad).
      // projects/{pid}/control_validations/{controlId__taskId} (client SDK,
      // controlValidationsStore). A project member records a validation;
      // validatedByUid must be the caller and is immutable on update; deleting a
      // safety validation is restricted to admin/supervisor. Read via the
      // sub-collection master-gate (isProjectMember).
      match /control_validations/{validationId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().validatedByUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().validatedByUid == existing().validatedByUid;
        allow delete: if isAdmin() || isSupervisor();
      }
      // Structural-load inputs (area/Cp/NCh-432 force limit) captured by an
      // operator and consumed by the Bernoulli wind-load predictive probe that
      // feeds AlertScheduler. A project member records inputs; createdBy must be
      // the caller and is immutable on update; deleting a structural-load record
      // (a safety input that drives wind-load alerting) is restricted to
      // admin/supervisor. Read is granted by the sub-collection master-gate
      // (isProjectMember). A record missing any physical input produces NO probe
      // server-side — the predictive ladder stays honestly silent, never firing
      // on a fabricated wind.
      match /structural_loads/{loadId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().createdBy == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().createdBy == existing().createdBy;
        allow delete: if isAdmin() || isSupervisor();
      }
      // SiteBook (libro de obras): legally-binding; immutable once signed.
      // B9: signed state is marked by `status == 'signed'` + a nested
      // `signature` map (signerUid/signedAt/algorithm/payloadHashHex) — this is
      // the ONLY shape any write-path emits (signEntry() in siteBookService.ts,
      // the adapter's tx.update({status:'signed',signature}), and the client
      // store save()). The previous gate checked a TOP-LEVEL `signedAt` that no
      // path ever wrote, so the clause was vacuously true and a signed record
      // stayed mutable. We now deny ANY update once status is 'signed' (or a
      // signature is already present). Corrections are NEW entries referencing
      // the original folio (createCorrection()), never in-place mutations.
      match /site_book/{docId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().recordedByUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && existing().status != 'signed'
          && !('signature' in existing())
          && incoming().recordedByUid == existing().recordedByUid;
        allow delete: if false;
      }
      match /site_book_entries/{entryId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().recordedByUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && existing().status != 'signed'
          && !('signature' in existing())
          && incoming().recordedByUid == existing().recordedByUid;
        allow delete: if false;
      }

      // -- Operational (member-write; admin/supervisor delete) ---------
      // B17 (Fase 5): a lone-worker session/event belongs to ONE worker. Only
      // that worker — or a rescue coordinator (admin/supervisor) — may update
      // it. Previously ANY project member could mutate another worker's session
      // (e.g. falsely flip a worker-in-distress to "safe"), masking a real
      // emergency. `isProjectMember` already subsumes admin/supervisor, so the
      // added clause is the owner-or-rescuer gate; `workerUid` stays immutable.
      match /lone_worker_sessions/{sessionId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().workerUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().workerUid == existing().workerUid
          && (existing().workerUid == request.auth.uid || isAdmin() || isSupervisor());
        allow delete: if isAdmin() || isSupervisor();
      }
      match /lone_worker_events/{eventId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().workerUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().workerUid == existing().workerUid
          && (existing().workerUid == request.auth.uid || isAdmin() || isSupervisor());
        allow delete: if isAdmin() || isSupervisor();
      }
      match /safety_talks_given/{talkId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().givenByUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().givenByUid == existing().givenByUid;
        allow delete: if isAdmin() || isSupervisor();
      }
      match /audit_portals/{portalId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().createdByUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().createdByUid == existing().createdByUid;
        allow delete: if isAdmin() || isSupervisor();
      }
      match /documents_for_read/{documentId} {
        allow create: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().authorUid == request.auth.uid;
        allow update: if isValidId(projectId) && isProjectMember(projectId)
          && incoming().authorUid == existing().authorUid;
        allow delete: if isAdmin() || isSupervisor();
      }
      // TODO(review dahosandoval@): no creator-uid field confirmed in the schema
      // for these three — anti-spoof N/A, so create/update is plain member-gated.
      // Tighten once the owner field (if any) is settled.
      match /exceptions/{exceptionId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }
      match /legal_obligations/{obligationId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }
      match /shifts/{shiftId} {
        allow create, update: if isValidId(projectId) && isProjectMember(projectId);
        allow delete: if isAdmin() || isSupervisor();
      }
    }

    match /nodes/{nodeId} {
      // PRIVACY (2026-06-08): nodes whose metadata carries a worker's raw RUT
      // (DS 67 / DS 109 legal-form modals) are medical/injury PII. They MUST NOT
      // be readable by every project member — only the node author and
      // admin/supervisor (the staff who file the DIAT/DIEP). Ordinary nodes keep
      // member-readability. The RUT stays in the node so SusesoReports.tsx (which
      // reads selectedIncident.metadata.workerRut for the DIAT/DIEP form) still
      // renders the real identifier for those authorized readers.
      //
      // PRIVACY (2026-06-08, remaining half of #776): the public-read branch
      // (existing().isPublic == true) must ALSO be guarded by !nodeHasWorkerRut().
      // The outer isEmailVerified() gate keeps anonymous callers out (and the
      // public-web PublicNodeView.tsx reads the SEPARATE `zettelkasten`
      // collection, not `nodes`), so the public flag here only ever widened
      // access to verified signed-in users — INCLUDING strangers from another
      // project/tenant. isValidNode() permits isPublic:true alongside
      // metadata.workerRut, and the author/admin/supervisor update rule can
      // toggle a node public, so a RUT-bearing node flagged isPublic:true leaked
      // the worker's national ID to any verified account. Guarding the public
      // branch closes that bypass: a RUT-bearing node is NEVER publicly readable
      // regardless of isPublic; genuinely public non-RUT nodes are unaffected.
      // PUBLIC WEB (2026-06-13): the anonymous QR-scan page
      // (src/pages/PublicNodeView.tsx, route /public/node/:nodeId — OUTSIDE the
      // auth-gated RootLayout) reads THIS canonical `nodes` collection. Praeventio
      // is an explorable public web (product_public_nologin_lifesaving): a node
      // explicitly flagged isPublic:true and carrying NO worker RUT is public
      // knowledge (a risk/control card on a worker badge), so it is readable by
      // ANYONE, including unauthenticated callers — this branch deliberately does
      // NOT require isEmailVerified(). The !nodeHasWorkerRut() guard keeps the
      // DS 67/109 PII nodes private even if mis-flagged isPublic (defence in depth
      // — same guard as the verified branch). All the OTHER access paths (author,
      // admin/supervisor, project member) stay verified-only.
      //
      // GET vs LIST split (2026-06-13, #876 — anti-enumeration): `read` is broken
      // into `get` (single-doc fetch by id) and `list` (collection query). The
      // anonymous public branch is granted on `get` ONLY — the QR-scan page
      // fetches exactly one node by its id, so anon never needs to LIST. Keeping
      // anon (and cross-tenant verified users) off the `list` surface prevents
      // enumeration of the whole knowledge graph: you can open a public node if
      // you already hold its id, but you cannot crawl every public node. `list`
      // is therefore membership-scoped (verified author/admin/supervisor/member),
      // mirroring the verified branch of the old `read` rule with no public clause.
      allow get: if (existing().isPublic == true && !nodeHasWorkerRut(existing()))
        || (isEmailVerified() && (
          existing().metadata.authorId == request.auth.uid ||
          isAdmin() ||
          isSupervisor() ||
          (isProjectMember(existing().projectId) && !nodeHasWorkerRut(existing()))
        ));
      allow list: if isEmailVerified() && (
          existing().metadata.authorId == request.auth.uid ||
          isAdmin() ||
          isSupervisor() ||
          (isProjectMember(existing().projectId) && !nodeHasWorkerRut(existing()))
        );
      allow create: if isEmailVerified() && isValidNode(incoming()) && incoming().metadata.authorId == request.auth.uid;
      allow update: if isEmailVerified() && isValidNode(incoming()) && (
        isAdmin() || 
        isSupervisor() || 
        existing().metadata.authorId == request.auth.uid ||
        incoming().diff(existing()).affectedKeys().hasOnly(['connections', 'updatedAt'])
      );
      allow delete: if isAdmin() || isSupervisor();
    }

    match /user_stats/{userId} {
      allow read: if isValidId(userId) && (isOwner(userId) || isAdmin() || isSupervisor());
      // XP is SERVER-AUTHORITATIVE (ADR / leaderboard integrity). `points`,
      // `medals`, `completedTrainings`, `safetyPosts` and `completedChallenges`
      // are awarded ONLY by the server (POST /api/gamification/points +
      // /check-medals, Admin SDK — which bypasses these rules). The owner-update
      // path previously let the owner self-edit those XP fields, which nullified
      // the server-authoritative XP and made the leaderboard trivially
      // manipulable. The owner may now only touch their own non-gameable session
      // /profile fields; any attempt to change an XP field falls through to deny.
      //
      // SECURITY (2026-06-13, review #876): `role` was REMOVED from this
      // allow-list. A user must never be able to write `role` into their own
      // user_stats doc — it is a privilege-escalation vector because a
      // server-side path that reads the whole user_stats doc could treat that
      // self-asserted role as authoritative. Role is provisioned exclusively by
      // admin/server flows on the canonical `users/{uid}` doc, never here.
      allow update: if isValidId(userId) && isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['loginStreak', 'lastLogin', 'displayName', 'updatedAt']);
      // SECURITY (2026-06-13, review #876): bootstrap create must NOT let the
      // owner pre-load server-authoritative XP. Previously only `points == 0`
      // was checked, leaving `medals`/`completedTrainings`/`safetyPosts`/
      // `completedChallenges` free to seed at create time (same leaderboard
      // bypass as the closed update path). Each of those fields, IF present,
      // must be the empty server-default: `medals` is an array → []; the
      // `completedChallenges` map (challenge -> ISO date) → {};
      // `completedTrainings`/`safetyPosts` are counters → 0. A client may omit
      // them entirely (the server fills them on first award). `role` is rejected
      // outright — same privilege-escalation guard as the update path.
      allow create: if isValidId(userId) && isOwner(userId)
        && incoming().points == 0
        && (!('medals' in incoming()) || incoming().medals == [])
        && (!('completedChallenges' in incoming()) || incoming().completedChallenges == {})
        && (!('completedTrainings' in incoming()) || incoming().completedTrainings == 0)
        && (!('safetyPosts' in incoming()) || incoming().safetyPosts == 0)
        && !('role' in incoming());
      allow delete: if isAdmin();
    }

    // Survival ping — life beacon written ~every 60s by useSurvivalPing
    // (pings/{uid}, client SDK, setDoc merge). The worker writes ONLY their own
    // beacon; rescue coordinators (admin/supervisor) read it to locate workers
    // in an emergency. Previously had no rule → the beacon was default-denied.
    match /pings/{pingUid} {
      allow read: if isValidId(pingUid) && (isOwner(pingUid) || isAdmin() || isSupervisor());
      allow create, update: if isValidId(pingUid) && isOwner(pingUid)
        && incoming().keys().hasOnly(['lat', 'lng', 'timestamp', 'status'])
        && incoming().status is string;
      allow delete: if false;
    }

    match /telemetry_events/{eventId} {
      allow read: if isAdmin() || isSupervisor();
      // Client-side creates are forbidden. Telemetry must flow through
      // /api/telemetry/ingest, which verifies a per-tenant HMAC-SHA256
      // signature over the canonical body before the admin SDK writes
      // here. Letting clients write directly bypasses HMAC and
      // cross-tenant guards. See src/server/middleware/canonicalBody.ts
      // and the rules tests in src/rules-tests/firestore.rules.test.ts.
      allow create: if false;
    }

    // SLO error-budget aggregation (SloErrorBudget.tsx reads
    // slo_metrics/{sloId}/daily). Platform observability written ONLY by the
    // server aggregation job (Admin SDK); the client reads the daily series to
    // render the error-budget dashboard. Read limited to admin/supervisor (the
    // dashboard audience); all client writes denied. Was default-denied → the
    // dashboard always fell back to synthetic data.
    match /slo_metrics/{sloId} {
      allow read: if isSignedIn() && (isAdmin() || isSupervisor());
      allow write: if false;
      match /daily/{dayId} {
        allow read: if isSignedIn() && (isAdmin() || isSupervisor());
        allow write: if false;
      }
    }

    // Digital-twin lifecycle calendar events (useObjectLifecycle →
    // top-level `calendar_events`, distinct from projects/{pid}/calendar_events).
    // Each doc carries `projectId` (CalendarEventSpec). Gated by membership of
    // THAT project so a member cannot create/read another project's reminders.
    // The Google Calendar retry job mutates `syncStatus` server-side (Admin SDK),
    // so client update/delete stay denied. Was default-denied → the local
    // source-of-truth doc never persisted before the sync attempt.
    match /calendar_events/{eventId} {
      allow read: if isSignedIn() && existing().projectId is string
        && isProjectMember(existing().projectId);
      allow create: if isSignedIn() && incoming().projectId is string
        && isProjectMember(incoming().projectId);
      allow update, delete: if false;
    }

    // Phase 5 — Per-project mesh signing key (HMAC-SHA-256). Distributed ONLY
    // through the server route GET /api/mesh/key (Admin SDK), gated by
    // verifyAuth + assertProjectMember. Clients must NEVER read it directly
    // (would expose the project secret in a member's browser console, letting
    // them forge mesh SOS packets) nor write it (would let one member overwrite
    // the trust root for the whole project). Default-deny both. Server reads via
    // Admin SDK bypass these rules. Exercised by
    // src/rules-tests/meshKeys.rules.test.ts.
    match /mesh_keys/{projectId} {
      allow read: if false;
      allow write: if false;
    }

    // Sprint 11 — Bernoulli-driven Zettelkasten nodes. Server-only writes
    // via POST /api/zettelkasten/nodes (verifyAuth + assertProjectMember
    // + zettelkastenWriteLimiter). Client-side reads están limitadas a
    // members del proyecto al que pertenece el nodo. Cualquier client
    // create/update/delete está prohibido — la única ruta legítima es
    // el endpoint server-side, que usa Admin SDK y bypasea estas reglas.
    match /zettelkasten_nodes/{nodeId} {
      allow read: if isSignedIn() && existing().projectId is string && isProjectMember(existing().projectId);
      allow create, update, delete: if false; // server-only via /api/zettelkasten/nodes
    }

    match /training/{sessionId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() || 
        (existing().projectId != null && isProjectMember(existing().projectId))
      );
      allow write: if isAdmin() || isSupervisor();
    }

    match /safety_solutions/{solutionId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() || 
        (existing().projectId != null && isProjectMember(existing().projectId))
      );
      allow write: if isAdmin() || isSupervisor();
    }

    match /normatives/{normativeId} {
      // §UX-anonymous (2026-05-21) — Datos normativos son regulación
      // PÚBLICA chilena/internacional (DS 44/2024, DS 594, DS 54, ISO
      // 45001, Ley 16.744, etc.). No contienen PII ni data privada de
      // empresa. Filosofía Instagram-style declarada por el usuario:
      // contenido público navegable sin login; login solo para SAVE.
      // Permitimos lectura anónima — gente buscando normativa SST
      // chilena (e.g. via Google) llega directo sin gating.
      //
      // Banking-grade: write sigue admin-only (auditable + immutable a
      // nivel app — `audit_logs` registran cambios).
      allow read: if true;
      allow write: if isAdmin();
    }

    // #4 — PUBLIC defibrillator (AED) registry. A bystander in a cardiac arrest
    // finds the nearest DEA WITHOUT login (life-safety public good, like an open
    // AED map; ADR 0021 — life-safety is never gated). No PII / no
    // company-private data — only a public location label, coordinates, status
    // and the source project id (mirrored from a project's per-project `deas` by
    // a member of that project). Read is open; WRITE is gated to members of the
    // owning project so randoms can't pollute the public map. Anonymous read +
    // write-deny are exercised by src/rules-tests/deaLocations.rules.test.ts.
    match /dea_locations/{deaLocationId} {
      allow read: if true;
      allow create, update: if isProjectMember(incoming().projectId)
        && isValidDeaLocation(incoming());
      allow delete: if isProjectMember(existing().projectId);
    }

    match /audit_logs/{logId} {
      // Audit trail is server-only: any client-side `create` is a self-fabrication
      // vector (a worker could log a fake "I revoked admin X" entry attributing
      // it to themselves and pollute the immutable audit history). All audit
      // writes happen via the Admin SDK from server.ts (e.g. /api/admin/set-role,
      // /api/admin/revoke-access), which bypasses these rules.
      // Client-side denial is exercised by src/rules-tests/firestore.rules.test.ts
      // (covers unauthenticated/worker/supervisor/gerente create + immutability).
      allow read: if isAdmin();
      allow create: if false; // server-only via Admin SDK
      allow update, delete: if false; // Immutable audit trail
    }

    match /vector_store/{docId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() || 
        (existing().projectId != null && isProjectMember(existing().projectId))
      );
      allow write: if isAdmin();
    }
    
    match /transactions/{transactionId} {
      allow read: if isOwner(get(/databases/$(database)/documents/transactions/$(transactionId)).data.userId) || isAdmin();
      allow write: if false; // Only server-side via Admin SDK
    }

    // Invitations — written by server (Admin SDK), read by invited user to see pending invites
    match /invitations/{inviteId} {
      allow read: if isEmailVerified() && (
        resource.data.invitedEmail == request.auth.token.email ||
        isAdmin() ||
        isProjectCreator(resource.data.projectId)
      );
      allow write: if false; // Only server-side via Admin SDK
    }

    // Gamification content — global content written by admins, readable by all authenticated users
    match /gamification_content/{contentId} {
      allow read: if isEmailVerified();
      allow write: if isAdmin();
    }

    // Community glossary — global shared knowledge, writable only by admins/supervisors.
    // §UX-anonymous (2026-05-21): glosario es contenido público (terminología
    // ocupacional, definiciones SST estándar). Lectura anónima OK — Instagram
    // model. Banking-grade: writes siguen admin/supervisor only.
    match /community_glossary/{termId} {
      allow read: if true;
      allow write: if isAdmin() || isSupervisor();
    }

    // Blueprints — project-scoped floor plans and technical drawings
    match /blueprints/{blueprintId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() ||
        isProjectMember(resource.data.projectId)
      );
      allow create: if isEmailVerified() && isProjectMember(incoming().projectId);
      allow update: if isEmailVerified() && (isAdmin() || isSupervisor() || isProjectCreator(resource.data.projectId));
      allow delete: if isAdmin() || isSupervisor() || isProjectCreator(resource.data.projectId);
    }

    // OAuth tokens — server-only via Admin SDK. Never readable from client.
    // Stored at oauth_tokens/{uid}_{provider} (e.g. abc123_google, abc123_google-drive).
    match /oauth_tokens/{tokenId} {
      allow read, write: if false;
    }

    // Global templates — seed data, read-only for all users.
    // §UX-anonymous (2026-05-21): templates de IPER, PTS, PREXOR son
    // referencia técnica pública. Permitir lectura anónima — usuarios
    // pueden inspirarse antes de registrarse (Instagram model).
    // Banking-grade: writes siguen admin-only.
    match /global_templates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Project documents — uploaded files scoped to a project
    match /project_documents/{docId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() ||
        isProjectMember(resource.data.projectId)
      );
      allow create: if isEmailVerified() && isProjectMember(incoming().projectId);
      allow delete: if isAdmin() || isSupervisor() || isProjectCreator(resource.data.projectId);
    }

    // Top-level worker documents — the projectId-less fallback of DocsModal
    // (`workers/{workerId}/documents/{id}`, client SDK addDoc/onSnapshot/
    // deleteDoc, fired when no project is selected). These are non-project-scoped
    // personnel records (certs, contracts, EPP, SUSESO docs) with no project
    // membership to check, so they are gated to prevention staff only
    // (admin/supervisor) for read/create/update; deleting a worker document
    // (compliance/legal trail) is likewise admin/supervisor. There is NO
    // top-level `match /workers` block elsewhere, so this path was fully
    // default-denied and the feature silently failed in that fallback.
    match /workers/{workerId}/documents/{documentId} {
      allow read: if isAdmin() || isSupervisor();
      allow create, update: if isAdmin() || isSupervisor();
      allow delete: if isAdmin() || isSupervisor();
    }

    // Driving reports — SafeDrivingMode writes; own user reads; supervisors/admins see all
    match /driving_reports/{reportId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() || resource.data.userId == request.auth.uid
      );
      allow create: if isEmailVerified()
        && incoming().userId == request.auth.uid
        && incoming().userId is string;
      allow update, delete: if false;
    }

    // AI feedback — users can submit vote on their own session; admins can read all
    match /ai_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isEmailVerified() && (
        incoming().userId == request.auth.uid || incoming().userId == null
      );
      allow update, delete: if false;
    }

    // Wisdom capsules — geo-activated knowledge attached to machines/locations
    match /wisdomCapsules/{capsuleId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && (isAdmin() || isSupervisor());
      allow update: if isEmailVerified() && (isAdmin() || isSupervisor());
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Round 16 R2 — closes Round 14/15 commit-message gaps.
    //
    // Round 14 R3 said it added rules for ergonomic_assessments +
    // iper_assessments and Round 15 R4 added 4 new collections without
    // any rules at all. ALL of those collections were silently denied
    // by the default-deny rule below in production. This block restores
    // the contracts those services rely on.
    //
    // Pattern (6 of 7 collections — gamification_scores deviates):
    //   • create  → project member; metadata.signedAt MUST be null.
    //   • update  → project member; metadata.signedAt STILL null;
    //               affectedKeys() restricted to a per-collection
    //               whitelist. Once signedAt is non-null nothing the
    //               client can do passes — the doc is append-only per
    //               Ley 16.744 Art. 76 + ISO 45001 §7.5.3 (Control of
    //               documented information).
    //   • delete  → false (immutable; legally-binding history).
    //   • read    → project member.
    // ===============================================================

    // Round 16 R2 — closes R14 R3 commit message gap (ergonomic_assessments).
    // REBA / RULA assessments. Engine: src/services/protocols/ergonomic.ts.
    // Writer: src/services/safety/ergonomicAssessments.ts.
    match /ergonomic_assessments/{assessmentId} {
      allow read: if isValidId(assessmentId) && isEmailVerified() && (
        isAdmin() || isSupervisor() ||
        isProjectMember(resource.data.projectId)
      );
      allow create: if isValidId(assessmentId) && isEmailVerified() &&
        isProjectMember(incoming().projectId) &&
        incoming().metadata.signedAt == null &&
        incoming().type in ['REBA', 'RULA'] &&
        incoming().score is number &&
        incoming().workerId is string &&
        incoming().projectId is string;
      allow update: if isValidId(assessmentId) && isEmailVerified() &&
        isProjectMember(resource.data.projectId) &&
        existing().metadata.signedAt == null &&
        incoming().diff(existing()).affectedKeys().hasOnly(['metadata', 'inputs', 'score', 'actionLevel']);
      allow delete: if false; // Ley 16.744 Art. 76 + ISO 45001 §7.5.3
    }

    // Round 16 R2 — closes R14 R3 commit message gap (iper_assessments).
    // IPER matrix (P x S). Engine: src/services/protocols/iper.ts.
    // Writer: src/services/safety/iperAssessments.ts.
    match /iper_assessments/{assessmentId} {
      allow read: if isValidId(assessmentId) && isEmailVerified() && (
        isAdmin() || isSupervisor() ||
        isProjectMember(resource.data.projectId)
      );
      allow create: if isValidId(assessmentId) && isEmailVerified() &&
        isProjectMember(incoming().projectId) &&
        incoming().metadata.signedAt == null &&
        incoming().inputs.probability is int &&
        incoming().inputs.probability >= 1 && incoming().inputs.probability <= 5 &&
        incoming().inputs.severity is int &&
        incoming().inputs.severity >= 1 && incoming().inputs.severity <= 5 &&
        incoming().level is string &&
        incoming().rawScore is number;
      allow update: if isValidId(assessmentId) && isEmailVerified() &&
        isProjectMember(resource.data.projectId) &&
        existing().metadata.signedAt == null &&
        incoming().diff(existing()).affectedKeys().hasOnly([
          'metadata', 'probability', 'severity', 'level',
          'rawScore', 'controlEffectiveness', 'suggestedControls'
        ]);
      allow delete: if false;
    }

    // B-protocols (2026-06-11) — MINSAL protocol assessments (TMERT-EESS /
    // PREXOR / PLANESI). Engines:
    // src/services/protocols/{tmert,prexor,planesi}.ts. Written
    // and read ONLY via the server routes under
    // /api/sprint-k/:projectId/protocols/* (verifyAuth +
    // assertProjectMember, Admin SDK — bypasses these rules). The server
    // recomputes the verdict from the raw inputs and stamps
    // `metadata.author` from the verified token, so a client-writable rule
    // would reopen the verdict/identity-spoof hole the server closes.
    // Default-deny would already cover it; the explicit block prevents a
    // future permissive rule from being added by accident (same rationale
    // as webauthn_challenges). Rules tests:
    // src/rules-tests/protocolAssessments.rules.test.ts.
    match /protocol_assessments/{assessmentId} {
      allow read, write: if false; // server-only via Admin SDK
    }

    // CEAL-SM/SUSESO psychosocial campaigns (Protocolo MINSAL oct. 2022) —
    // server-only, same rationale as protocol_assessments PLUS anonymity:
    // the `responses` subcollection holds anonymous worker answers about
    // their employer (doc id = peppered responder hash, never a uid). Any
    // client read would bypass the k>=10 aggregate suppression gate in
    // /api/sprint-k/:projectId/ceal-sm/* and allow per-respondent answer
    // inspection; any client write would let a manager fabricate responses
    // and tilt the center verdict. Explicit deny so a future permissive
    // rule isn't added by accident. Rules tests:
    // src/rules-tests/cealSmCampaigns.rules.test.ts.
    match /ceal_sm_campaigns/{campaignId} {
      allow read, write: if false; // server-only via Admin SDK (k-gated)
      match /responses/{responderHash} {
        allow read, write: if false; // anonymous answers — never client-visible
      }
    }

    // Round 16 R2 — closes R15 R4 gap (gamification_scores).
    // Per-user-per-game best-score doc, id `${uid}_${gameId}` (claw machine,
    // pool game, etc.). DEVIATES from append-only-after-sign pattern:
    // gamification scores are mutable — only the same user can write their
    // own row, and only fields on the whitelist. Source: gameScore.ts.
    match /gamification_scores/{scoreId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow create: if isEmailVerified() &&
        incoming().userId == request.auth.uid &&
        incoming().gameId is string &&
        incoming().bestScore is number;
      allow update: if isEmailVerified() &&
        existing().userId == request.auth.uid &&
        incoming().userId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly([
          'bestScore', 'bestTimeSeconds', 'lastScore', 'lastPlayedAt',
          'plays', 'attempts', 'updatedAt', 'updatedBy'
        ]);
      // Per-user historical record — preserve trajectory; do not allow purge.
      allow delete: if false;
    }

    // Round 16 R2 — closes R15 R4 gap (lighting_audits).
    // Phase 5 (B-lighting): fix vacuous post-sign gate.
    // Lux measurements vs DS 594 Art. 103 thresholds.
    // Writer: src/pages/LightPollutionAudit.tsx (save() writes a TOP-LEVEL
    // boolean `signed`; it never writes a `metadata` object).
    //
    // The previous gate checked `metadata.signedAt`, which NO write path ever
    // sets, so `!('metadata' in existing())` was always true and the clause
    // was vacuously satisfied — a signed lighting certificate stayed fully
    // mutable, and `signed` itself was in the mutable allowlist so it could be
    // flipped back to false. Same defect class already fixed for site_book
    // above. We now gate on the REAL field (`signed`) and deny ANY update once
    // `signed == true`. A finalized DS 594 certificate is append-only:
    // corrections are NEW audits, never in-place rewrites.
    match /lighting_audits/{auditId} {
      allow read: if isValidId(auditId) && isEmailVerified() && (
        isAdmin() || isSupervisor() ||
        isProjectMember(resource.data.projectId)
      );
      // New audits must be created unsigned; the immutable lock is the
      // top-level `signed` flag, so it must start false (or be absent).
      allow create: if isValidId(auditId) && isEmailVerified() &&
        isProjectMember(incoming().projectId) &&
        (!('signed' in incoming()) || incoming().signed == false);
      // Pre-sign: a project member may edit measurements OR sign the audit
      // (false -> true). Post-sign: every update is denied. `signed` may only
      // move false -> true, never true -> false.
      allow update: if isValidId(auditId) && isEmailVerified() &&
        isProjectMember(resource.data.projectId) &&
        existing().signed != true &&
        incoming().signed in [true, false] &&
        incoming().diff(existing()).affectedKeys().hasOnly([
          'measurementsLux', 'averageLux',
          'compliantAreas', 'nonCompliantAreas', 'compliant', 'signed'
        ]);
      allow delete: if false;
    }

    // Round 16 R2 — closes R15 R4 gap (uv_exposures).
    // Per-user-per-day UV exposure (DS 594 Art. 110 / Ley 20.096).
    // Doc id: `${uid}_${YYYY-MM-DD}`. Worker writes their own; merge for
    // peakUv accumulation. Writer: src/pages/SunTracker.tsx.
    match /uv_exposures/{exposureId} {
      allow read: if isEmailVerified() && (
        isAdmin() || isSupervisor() ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow create: if isEmailVerified() &&
        incoming().userId == request.auth.uid &&
        incoming().date is string;
      allow update: if isEmailVerified() &&
        existing().userId == request.auth.uid &&
        incoming().userId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly([
          'peakUv', 'cumulativeMinutes', 'alertEmittedAt',
          'cloudCover', 'latitude', 'lastTimeOfDay', 'updatedAt'
        ]);
      allow delete: if false;
    }

    // Round 16 R2 — closes R15 R4 gap (safety_trainings).
    // Training-completion record (e.g. webxr.height-work / DS 594 Art. 53).
    // Writer: src/pages/WebXR.tsx + future training pages.
    match /safety_trainings/{trainingId} {
      allow read: if isValidId(trainingId) && isEmailVerified() && (
        isAdmin() || isSupervisor() ||
        (resource != null && resource.data.traineeUid == request.auth.uid) ||
        (resource != null && resource.data.projectId != null &&
          isProjectMember(resource.data.projectId))
      );
      allow create: if isValidId(trainingId) && isEmailVerified() &&
        incoming().traineeUid == request.auth.uid &&
        (!('metadata' in incoming()) || incoming().metadata.signedAt == null);
      allow update: if isValidId(trainingId) && isEmailVerified() &&
        (existing().traineeUid == request.auth.uid || isAdmin() || isSupervisor()) &&
        (!('metadata' in existing()) || existing().metadata.signedAt == null) &&
        incoming().diff(existing()).affectedKeys().hasOnly([
          'metadata', 'completedAt', 'score', 'certificateId',
          'verifiedItems'
        ]);
      allow delete: if false;
    }

    // Round 17 (R5) — WebAuthn challenge cache.
    //
    // Server-issued, single-use, TTL-bound challenges that close the
    // R6/R16 MEDIUM finding (client-generated WebAuthn challenges are
    // replay-vulnerable). Doc id: `${uid}_${challengeId}`. Writes happen
    // ONLY through src/services/auth/webauthnChallenge.ts via the Admin
    // SDK (server.ts /api/auth/webauthn/challenge endpoint). The default
    // -deny block above is enough to lock clients out, but we keep an
    // explicit deny rule here for clarity (so future agents don't add a
    // permissive rule by accident).
    //
    // ISO 27001 §A.9.4.1 — server-side authentication state must not be
    // mutable by the authenticating party.
    match /webauthn_challenges/{docId} {
      allow read, write: if false; // Server-only via Admin SDK
    }

    // Round 14 (R5) — Curriculum claims (Experience-Validation System).
    //
    // The flagship anti-fraud feature. A worker creates a claim about
    // their own experience; 2 named referees co-sign via a magic-link
    // emailed to them. Once both co-sign, the doc becomes immutable.
    //
    // Security envelope:
    //   • Worker can CREATE only their own claim (workerId == uid) and
    //     only in the initial 'pending_referees' state.
    //   • Worker can READ their own claims (admin can read any).
    //   • Referee co-signature does NOT happen via these rules: the
    //     POST /api/curriculum/referee/:token endpoint uses the Admin
    //     SDK (which bypasses these rules) after verifying the token
    //     hash. We DENY all client updates to keep verified claims
    //     immutable from the client side.
    //   • DELETE is permanently denied — verified claims are part of
    //     the worker's portable curriculum and must persist.
    match /curriculum_claims/{claimId} {
      allow read: if isEmailVerified() && (
        isAdmin() ||
        (resource != null && resource.data.workerId == request.auth.uid)
      );
      allow create: if isEmailVerified() &&
        incoming().workerId == request.auth.uid &&
        incoming().status == 'pending_referees' &&
        incoming().claim is string &&
        incoming().claim.size() > 0 && incoming().claim.size() <= 500 &&
        incoming().referees is list && incoming().referees.size() == 2 &&
        incoming().verifiedAt == null;
      // Updates and deletes go ONLY through the server (Admin SDK).
      // Client-side cosign or tampering is denied.
      allow update, delete: if false;
    }

    // ===============================================================
    // Sprint 15 — Organic structure: Crew, Process, Task
    // ===============================================================
    // Reads: any project member can read crews/processes/tasks for that
    // project. Writes for `crews` and `processes` are server-only (Admin
    // SDK) so the positive-only XP economy can never be tampered with
    // from the client. `tasks` allow project-member writes restricted to
    // a closed key set + a 3-step status pipeline.

    match /crews/{crewId} {
      allow read: if isProjectMember(resource.data.projectId);
      allow create, update, delete: if false;
    }

    match /processes/{processId} {
      allow read: if isProjectMember(resource.data.projectId);
      allow create, update, delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if isProjectMember(resource.data.projectId);
      // Project members may create + update task docs, with shape pinned
      // to a closed key set. Status enum is enforced. Deletes are denied
      // to preserve the audit trail.
      allow create: if isProjectMember(incoming().projectId)
        && incoming().keys().hasOnly([
          'description', 'assignedUids', 'status', 'date',
          'crewId', 'processId', 'projectId', 'completedAt'
        ])
        && incoming().status in ['pending', 'doing', 'done']
        && incoming().description is string
        && incoming().date is string;
      allow update: if isProjectMember(resource.data.projectId)
        && incoming().keys().hasOnly([
          'description', 'assignedUids', 'status', 'date',
          'crewId', 'processId', 'projectId', 'completedAt'
        ])
        && incoming().status in ['pending', 'doing', 'done'];
      allow delete: if false;
    }

    // ===============================================================
    // Sprint 27 (audit P0 H8) — `tenants/*` collection.
    //
    // The server (Admin SDK) writes per-tenant configuration here:
    // billing entitlements, data residency, retention policies, etc.
    // The client only ever needs to *read* its own tenant doc to
    // surface entitlement state; mutations are server-only.
    //
    // Auth model: a custom claim `tenantId` is set on the user's token
    // when they accept a tenant invite (see oauthGoogle.ts /
    // adminClaims). A user can read tenants/{X} iff their claim
    // tenantId == X. Writes/creates/deletes are denied to all clients;
    // the server uses the Admin SDK which bypasses these rules.
    //
    // Without this matcher, Firestore default-deny silently rejected
    // every client read — leaving the `tenants/*` surface invisible
    // and ungrep-able. Audit hallazgo H8.
    match /tenants/{tenantId} {
      allow read: if isSignedIn()
        && isMemberOfTenant(tenantId);
      allow create, update, delete: if false;

      // Subcollections (entitlements, audit_summaries, etc.) follow
      // the same tenant-claim gate. The server owns writes.
      //
      // 2026-05-15 fix: en Firestore rules, los `match` que se solapan se
      // combinan con OR sobre los `allow`. Este catchall daba lectura a
      // CUALQUIER tenant member, incluyendo subcolecciones que tienen
      // matchers hermanos más estrictos (`supervisor_only`, `suseso_forms`,
      // `suseso_counters`). El OR anulaba esos checks. Excluimos esas rutas
      // de aquí para que la regla estricta sea la única aplicable.
      match /{subcoll}/{docId} {
        allow read: if isSignedIn()
          && isMemberOfTenant(tenantId)
          && !(subcoll in ['supervisor_only', 'suseso_forms', 'suseso_counters', 'conflict_queue', 'evidence_artifacts']);
        allow create, update, delete: if false;
      }

      // A4 follow-up re-scope 2026-06: tenants/{tid}/seismic_events is GONE.
      // The §365 fix added a tenant-member create rule here, but the writer
      // (EmergencyOverlay) keyed the path with `window.__GP_TENANT_ID__ ||
      // 'default'` (a global no install ever assigns) and isMemberOfTenant()
      // requires claims no flow mints — the path was unreachable in
      // production AND a dormant client-writable surface. The collection now
      // lives under projects/{pid}/seismic_events (see the projects block),
      // mirroring the PR #847 system_events re-scope. Writes here fall to
      // the tenant catch-all default-deny above.

      // Fase D.4 — tenant-scoped supervisor-only subcollection.
      // Used by audit_summaries, supervisor_briefings, cross_project_kpis, …
      // Cualquier doc bajo /tenants/{tid}/supervisor_only/* solo lo lee
      // un usuario con role supervisor-tier Y vínculo al tenant.
      match /supervisor_only/{docId} {
        allow read: if isSignedIn() && isSupervisorOfTenant(tenantId);
        allow create, update, delete: if false;
      }

      // ===============================================================
      // Sprint 28 Bucket B6 — SUSESO DIAT/DIEP forms.
      //
      // Cierra audit hallazgo H28 (P1). Forms son IMMUTABLES post-
      // creación: la firma se aplica vía Admin SDK del backend (que
      // bypasea estas reglas). Cliente NO puede update/delete bajo
      // ninguna circunstancia — re-firmar requiere un nuevo folio.
      //
      // Read: cualquier miembro del proyecto referenciado en el form,
      // O cualquier admin/médico del tenant — los médicos necesitan
      // visibilidad total sobre DIAT/DIEP del paciente.
      //
      // Create: redundante (el server siempre crea via Admin SDK), pero
      // dejamos la regla explícita para que el modelo de seguridad
      // sea legible sin necesidad de leer server code.
      match /suseso_forms/{formId} {
        allow read: if isSignedIn()
          && isMemberOfTenant(tenantId)
          && (
            isAdmin() ||
            isSupervisor() ||
            isDoctor() ||
            (resource.data.projectId is string
              && isProjectMember(resource.data.projectId))
          );
        allow create: if isSignedIn()
          && (isAdmin() || isSupervisor() || isDoctor());
        // Forms IMMUTABLE — only Admin SDK (server) attaches signatures.
        allow update, delete: if false;
      }

      // SUSESO folio counters. Server-only; clients never need to read.
      match /suseso_counters/{counterId} {
        allow read, write: if false;
      }

      // ===============================================================
      // §12.2.2 / B16 — Safety-doc conflict queue.
      //
      // Two offline writers diverged on a legally-binding field (incident
      // severity, medical aptitude, training cert, …). The entry is written
      // ONLY by the server (src/server/routes/conflictQueue.ts via Admin
      // SDK, which bypasses these rules) so identity + status transitions
      // are server-stamped and approver-gated. Clients NEVER write here —
      // resolution flows through the audited, approver-gated server route,
      // not a direct client write.
      //
      // Read: supervisor-tier of THIS tenant (so a gerente/admin can see
      // the queue and resolve it). Workers do not read other workers'
      // conflict decisions.
      match /conflict_queue/{queueId} {
        allow read: if isSignedIn() && isSupervisorOfTenant(tenantId);
        allow create, update, delete: if false;
      }

      // ===============================================================
      // B4 / audit H8 — Evidence chain-of-custody (Sprint 39 Fase J.7).
      //
      // Modelo: tenants/{tid}/evidence_artifacts/{hash}              (artifact)
      //         tenants/{tid}/evidence_artifacts/{hash}/events/{eid} (custody log)
      //
      // The custody engine + adapter (src/services/evidenceChain/*) were inert
      // dead-code until src/server/routes/custodyChain.ts mounted them. ALL
      // writes flow through that verifyAuth + assertProjectMember route via the
      // Admin SDK (which bypasses these rules and server-stamps uploadedByUid /
      // actorUid from the verified token). Clients NEVER write here directly:
      //
      //   • Artifact reads — any member of THIS tenant. A content-addressed
      //     evidence record (photo/PDF/declaration hash + metadata) is part of
      //     the incident expediente the tenant is entitled to inspect.
      //   • Events subcollection is APPEND-ONLY by design (legal chain of
      //     custody): create is server-only (Admin SDK), and update/delete are
      //     hard-denied so no link in the custody trail can be rewritten or
      //     erased — same immutability anchor as audit_logs / suseso_forms.
      //   • Direct client create/update/delete on artifacts is denied; an
      //     artifact's hash is its identity and "replacement" is recorded as a
      //     NEW event + a server-applied `replacedByHash`, never an in-place
      //     edit by the client.
      // ===============================================================
      match /evidence_artifacts/{hash} {
        allow read: if isSignedIn() && isMemberOfTenant(tenantId);
        // Writes are Admin-SDK only (the audited custodyChain route).
        allow create, update, delete: if false;

        // Custody events — APPEND-ONLY immutable log. No client write at all;
        // update/delete denied to anyone (incl. the server would re-create, not
        // mutate). Reads gated to tenant members like the parent artifact.
        match /events/{eventId} {
          allow read: if isSignedIn() && isMemberOfTenant(tenantId);
          allow create, update, delete: if false;
        }
      }

      // ===============================================================
      // Sprint F (2026-05-16) — AR Anchors per project.
      //
      // Modelo: tenants/{tid}/projects/{pid}/ar_anchors/{anchorId}
      //
      // El usuario describió la directiva: "los nodos de información en
      // la maquinaria de la empresa con coordenadas, esa información es
      // privada por proyecto". Estas reglas son la barrera de privacidad
      // de los datos AR — solo miembros del project pueden leer/crear/
      // actualizar/eliminar SUS PROPIAS anclas.
      //
      // Validación al crear:
      //  - createdByUid debe ser el caller (no se puede crear ancla
      //    suplantando otro UID)
      //  - projectId/tenantId deben coincidir con la ruta
      //  - kind debe ser uno de los discriminator types definidos
      //  - matrix debe ser una lista de 16 numbers (validamos length)
      //  - label es string no vacío con tope de 200 chars
      //
      // Update: solo el creador, admin o supervisor del proyecto.
      // Delete: solo creador o admin (no supervisor — el ancla puede
      //   ser evidencia de inspección, no debería borrarse a la ligera).
      // ===============================================================
      match /ar_anchors/{anchorId} {
        // Path: tenants/{tid}/ar_anchors/{id}
        // (consistente con supervisor_only/, suseso_forms/ — tenant
        // subcollection directa, projectId vive como FIELD del doc).
        //
        // Validación project-scoping: la app filtra por
        // `where('projectId','==',selectedProject.id)` client-side,
        // pero NO podemos enforcing eso en rules sin un get() costoso.
        // Aceptamos eso porque el tenantId aquí ya garantiza que solo
        // miembros del tenant ven CUALQUIER anchor del tenant — el
        // project-scope sirve para ORGANIZACIÓN (filtrar UI), no como
        // privacy boundary fuerte. Si se necesita aislamiento estricto
        // entre proyectos del mismo tenant, migrar a path 4-niveles
        // tenants/{tid}/projects/{pid}/ar_anchors/{id} con rule wrap.

        allow read: if isSignedIn() && isMemberOfTenant(tenantId);

        allow create: if isSignedIn()
          && isMemberOfTenant(tenantId)
          && incoming().tenantId == tenantId
          && incoming().createdByUid == request.auth.uid
          && incoming().kind in ['machinery', 'warehouse_object', 'poster']
          && incoming().projectId is string
          && incoming().projectId.size() > 0
          && incoming().label is string
          && incoming().label.size() > 0
          && incoming().label.size() <= 200
          && incoming().matrix is list
          && incoming().matrix.size() == 16;

        allow update: if isSignedIn()
          && isMemberOfTenant(tenantId)
          && (
            resource.data.createdByUid == request.auth.uid
            || isAdmin()
            || isSupervisorOfTenant(tenantId)
          )
          // No cambiar identity fields después de crear.
          && incoming().tenantId == resource.data.tenantId
          && incoming().projectId == resource.data.projectId
          && incoming().createdByUid == resource.data.createdByUid
          && incoming().kind == resource.data.kind;

        allow delete: if isSignedIn()
          && isMemberOfTenant(tenantId)
          && (
            resource.data.createdByUid == request.auth.uid
            || isAdmin()
          );
      }

      // ===============================================================
      // OLA 1 (VIDA, 2026-06-14) — per-project life-safety subcollections.
      //
      // The tenants/{tid} block previously had ONLY a single-level catch-all
      // (`match /{subcoll}/{docId}`, 4-segment paths). The 6-segment paths
      // tenants/{tid}/projects/{pid}/<X>/<id> therefore fell to the global
      // default-deny (see the ar_anchors comment above: "migrar a path
      // 4-niveles ... con rule wrap"). That wrap is THIS block. Without it the
      // digital-twin A* evacuation map and the live evacuation headcount were
      // dead in production (their CLIENT reads were PERMISSION_DENIED) even
      // though their consumers are mounted. Life-safety = FREE on every tier
      // (ADR 0021); never tier-gate these.
      match /projects/{projectId} {
        // Digital-twin site geometry — polygons (buildings/zones/obstacles)
        // that feed the A* evacuation route in DynamicEvacuationMap. DRAWN
        // client-side by an admin/supervisor (siteGeometryStore.savePolygon →
        // setDoc) and read live by every tenant member (the route is shown to
        // workers during an evacuation). Shape: {id,type,label,heightM,
        // notes?,coordinates:[lng,lat][],updatedAt}.
        match /site_geometry/{geomId} {
          allow read: if isSignedIn() && isMemberOfTenant(tenantId);
          allow create, update: if isSignedIn()
            && isMemberOfTenant(tenantId)
            && (isAdmin() || isSupervisorOfTenant(tenantId))
            && incoming().label is string
            && incoming().label.size() > 0
            && incoming().label.size() <= 200
            && incoming().type is string
            && incoming().heightM is number
            && incoming().coordinates is list
            && incoming().coordinates.size() >= 3;
          allow delete: if isSignedIn()
            && isMemberOfTenant(tenantId)
            && (isAdmin() || isSupervisorOfTenant(tenantId));
        }

        // Evacuation drills — live headcount during a REAL evacuation (who is
        // safe vs still missing). Written ONLY by the audited server route
        // (evacuationHeadcount.ts: start/scan/end via Admin SDK, which bypasses
        // these rules and server-stamps startedByUid/scannedByUid). Clients
        // never write. Read by every tenant member so supervisors AND workers
        // see the headcount in real time.
        match /evacuations/{drillId} {
          allow read: if isSignedIn() && isMemberOfTenant(tenantId);
          allow create, update, delete: if false;

          // Per-worker QR scan rows — server-stamped, append-only.
          match /scans/{workerUid} {
            allow read: if isSignedIn() && isMemberOfTenant(tenantId);
            allow create, update, delete: if false;
          }
        }

        // OLA 2 (blindaje, 2026-06-14) — server-only-write tenant stores that
        // previously had NO rule under this block (no recursive catch-all here,
        // unlike projects/{pid}/** which the master-gate covers). They are
        // written ONLY by audited server routes via the Admin SDK (which bypasses
        // these rules + server-stamps identity); clients NEVER write. The rule
        // makes that posture EXPLICIT: tenant members may READ, all client writes
        // are denied — so a future client read works and an accidental client
        // write can never land. Life-safety/cultural data: free on every tier.

        // Positive safety observations (behavioral recognition; server route
        // positiveObservations.ts stamps observerUid/observedWorkerUid).
        match /positive_observations/{observationId} {
          allow read: if isSignedIn() && isMemberOfTenant(tenantId);
          allow create, update, delete: if false;
        }

        // Content-addressed photo evidence (server route photoEvidence.ts).
        match /photo_evidence/{contentHash} {
          allow read: if isSignedIn() && isMemberOfTenant(tenantId);
          allow create, update, delete: if false;
        }

        // Gaussian-splat 3D captures — digital-twin geometry (server adapter
        // gaussianSplatFirestoreAdapter.ts).
        match /splat_captures/{captureId} {
          allow read: if isSignedIn() && isMemberOfTenant(tenantId);
          allow create, update, delete: if false;
        }
      }
    }

    // ===============================================================
    // Sprint 28 Bucket B5 — CPHS (Comité Paritario de Higiene y
    // Seguridad). Cierra audit hallazgo H29 P1.
    //
    // Modelo de auth:
    //   • READ: cualquier miembro del proyecto (isProjectMember).
    //   • CREATE/UPDATE comité: admin/gerente del proyecto, O bien
    //     un miembro que ya esté listado en `members[].uid` del comité
    //     existente (al constituir el comité, el `incoming.members`
    //     debe incluir al caller).
    //   • Reuniones: members del proyecto pueden crear/agendar y
    //     escribir minutes; pero una vez `signatures.size() >= 1` el
    //     documento es IMMUTABLE excepto por APPEND a `signatures[]`.
    //     Mismo patrón que audit_logs.
    //
    // Helpers locales: isCphsMember verifica que el caller esté en
    // members[] del comité (sin discriminar empleador/trabajador —
    // todos los integrantes del CPHS pueden firmar y leer).
    // ===============================================================

    function isCphsMember(committeeData) {
      // committeeData.members es lista de objetos {uid,fullName,role,side,elected}.
      // CEL no permite map sobre lista, pero sí `.hasAny([{...}])` con un
      // patrón fijo. En la práctica delegamos en server.ts: el client
      // sólo necesita poder leer el comité para luego escribir reuniones.
      // Aquí chequeamos pertenencia básica iterando con `in` sobre los
      // uids planos que el server materializa en `committeeData.memberUids`.
      return isSignedIn()
        && committeeData.memberUids is list
        && request.auth.uid in committeeData.memberUids;
    }

    match /cphs_committees/{committeeId} {
      allow read: if isProjectMember(resource.data.projectId);
      allow create: if isEmailVerified()
        && isProjectMember(incoming().projectId)
        && (isAdmin() || isSupervisor())
        && incoming().status == 'active'
        && incoming().members is list
        && incoming().members.size() >= 6;
      allow update: if isEmailVerified()
        && isProjectMember(resource.data.projectId)
        && (isAdmin() || isSupervisor() || isCphsMember(resource.data))
        // projectId / createdBy / createdAt no mutables.
        && incoming().projectId == resource.data.projectId
        && incoming().createdBy == resource.data.createdBy
        && incoming().createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /cphs_meetings/{meetingId} {
      allow read: if isSignedIn()
        && exists(/databases/$(database)/documents/cphs_committees/$(resource.data.committeeId))
        && isProjectMember(
          get(/databases/$(database)/documents/cphs_committees/$(resource.data.committeeId)).data.projectId
        );
      allow create: if isEmailVerified()
        && incoming().committeeId is string
        && exists(/databases/$(database)/documents/cphs_committees/$(incoming().committeeId))
        && isProjectMember(
          get(/databases/$(database)/documents/cphs_committees/$(incoming().committeeId)).data.projectId
        )
        && incoming().status in ['scheduled', 'held', 'cancelled']
        && incoming().signatures is list
        && incoming().signatures.size() == 0;
      // Una vez firmada (signatures.size() >= 1) el acta es IMMUTABLE
      // excepto por APPEND a signatures[] — mismo patrón que audit_logs.
      // Antes de la primera firma, miembros del proyecto pueden modificar
      // minutes/resolutions/attendees/status (recordMinutes flow).
      allow update: if isEmailVerified()
        && isProjectMember(
          get(/databases/$(database)/documents/cphs_committees/$(resource.data.committeeId)).data.projectId
        )
        // Invariantes hoisted a TODOS los sub-casos: committeeId y
        // scheduledAt nunca mutan, y signatures siempre debe ser una lista.
        && incoming().committeeId == resource.data.committeeId
        && incoming().scheduledAt == resource.data.scheduledAt
        && incoming().signatures is list
        && (
          // Caso A1 — BORRADOR (acta sin firmar, signatures sigue vacío):
          // libre edición de campos operativos (recordMinutes flow).
          (resource.data.signatures.size() == 0
            && incoming().signatures.size() == 0
          )
          ||
          // Caso A2 — PRIMERA FIRMA (transición 0 -> 1). Misma disciplina
          // self-binding que el append de Caso B: EXACTAMENTE una firma, su
          // uid DEBE ser el del que escribe (no se puede plantar la firma de
          // otro miembro), y NO se puede plantar un lote de N firmas pre-
          // forjadas (tamaño cap a 1). El cuerpo del acta queda bit-a-bit
          // idéntico — la transición de primera firma NO puede manipular
          // agenda/minutes/resolutions/attendees/status. Sin esto, sobre un
          // acta sin firmar cualquier miembro podría en UNA sola escritura
          // (a) firmar bajo el uid de otro, (b) plantar N firmas WebAuthn
          // pre-forjadas saltándose la ceremonia per-member, y (c) mutar el
          // cuerpo a la vez que bloquea el doc (Caso B lo vuelve inmutable).
          (resource.data.signatures.size() == 0
            && incoming().signatures.size() == 1
            && incoming().signatures[0].uid == request.auth.uid
            && incoming().agenda == resource.data.agenda
            && incoming().minutes == resource.data.minutes
            && incoming().resolutions == resource.data.resolutions
            && incoming().attendees == resource.data.attendees
            && incoming().status == resource.data.status
          )
          ||
          // Caso B: APPEND-only a signatures[] (acta ya firmada) — el resto
          // debe quedar bit-a-bit idéntico (immutability post-firma). El
          // array de firmas SÓLO puede crecer en exactamente 1 y DEBE
          // preservar el prefijo existente sin reescribir ninguna firma
          // previa: el nuevo array tiene que ser EXACTAMENTE el anterior +
          // el elemento agregado al final (`concat`). Sin esto, un miembro
          // podría enviar un array de tamaño N+1 con las firmas WebAuthn
          // previas forjadas/reescritas (uid/credentialId/signature/
          // signedAt) — el chequeo de tamaño solo NO lo impide. Además la
          // firma agregada al final DEBE ser auto-firmada (uid == caller),
          // de modo que nadie pueda co-firmar bajo el uid de otro miembro.
          (resource.data.signatures.size() >= 1
            && incoming().agenda == resource.data.agenda
            && incoming().minutes == resource.data.minutes
            && incoming().resolutions == resource.data.resolutions
            && incoming().attendees == resource.data.attendees
            && incoming().status == resource.data.status
            && incoming().signatures.size() == resource.data.signatures.size() + 1
            && incoming().signatures[resource.data.signatures.size()].uid == request.auth.uid
            && incoming().signatures
               == resource.data.signatures.concat(
                    [incoming().signatures[resource.data.signatures.size()]]
                  )
          )
        );
      allow delete: if false;
    }
  }
}
