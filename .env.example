# Praeventio Guard — environment variable template.
#
# Copy this file to `.env.local` (gitignored) for development and to your
# secret manager (Cloud Run, GitHub Actions, etc.) for production.
#
# Run `npm run validate:env` BEFORE booting in production. The validator
# rejects placeholders and short secrets and points back here.
#
# For step-by-step "where do I get this value" instructions for every
# variable below, see: docs/runbooks/SECRETS_RUNBOOK.md
#
# Convention: `<...>` markers describe what the real value should look
# like. Anything matching `^(YOUR_|MY_|REPLACE_|PLACEHOLDER|<.*>)` is
# rejected by validate-env.cjs in prod mode.

# === SECTION: AI ===

# GEMINI_API_KEY: Required for Gemini AI API calls.
# Obtain at https://aistudio.google.com/app/apikey
# AI Studio also injects this at runtime from user secrets when the
# applet runs in Cloud Run.
GEMINI_API_KEY=<paste-from-aistudio.google.com/app/apikey>

# === SECTION: App URLs ===

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run
# service URL. Used for self-referential links, OAuth callbacks, billing
# returns and API endpoints.
APP_URL=<https://your-domain.com>

# APP_BASE_URL: Used to build Webpay return URL
# (`${APP_BASE_URL}/billing/webpay/return`).
# Dev: http://localhost:5173 (Vite). Prod: canonical app URL
# (https://app.praeventio.net).
APP_BASE_URL=<https://app.praeventio.net>

# === SECTION: Maps ===

# Google Maps JavaScript API key. Powers Site25DPanel + 4 emergency maps
# (SiteMap, Coastal/VolcanicEruptionMap, DynamicEvacuationMap).
# Restrict to your domain in console.cloud.google.com/apis/credentials.
VITE_GOOGLE_MAPS_API_KEY=<paste-from-console.cloud.google.com/apis/credentials>

# === SECTION: Auth (Google OAuth) ===

# Google Calendar + Fit OAuth credentials (Web application client).
# console.cloud.google.com → APIs & Services → Credentials → Create OAuth client.
GOOGLE_CLIENT_ID=<oauth-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<oauth-client-secret>

# === SECTION: Weather (optional) ===

# OpenWeatherMap API key — alternative to Open-Meteo (which requires no key).
# Open-Meteo is preferred; only set this if you need OWM features.
VITE_OPENWEATHER_API_KEY=<optional-paste-from-openweathermap.org>

# === SECTION: RAG / Pinecone (optional) ===

# Pinecone vector DB for RAG over BCN normativa. Without this, RAG falls
# back to in-memory mode (degraded but functional).
PINECONE_API_KEY=<optional-paste-from-app.pinecone.io>
PINECONE_INDEX_NAME=praeventio-guard

# === SECTION: Push Notifications ===

# Firebase Cloud Messaging Web Push VAPID public key.
# Firebase Console → Project settings → Cloud Messaging → Web configuration.
VITE_FIREBASE_VAPID_KEY=<paste-vapid-public-key-from-firebase-console>

# === SECTION: Server secrets ===

# express-session signing secret. MUST be at least 32 chars.
# Generate with: `openssl rand -hex 32`
SESSION_SECRET=<openssl-rand-hex-32>

# IoT telemetry HMAC secret. MUST be at least 32 chars.
# Generate with: `openssl rand -hex 32`
# Used to verify HMAC-SHA256 on /api/telemetry/ingest (canonical-JSON
# body, see src/server/middleware/canonicalBody.ts).
IOT_WEBHOOK_SECRET=<openssl-rand-hex-32>

# === SECTION: Legacy / migration flags ===

# Round 18 R6 — emergency rollback for the canonical-JSON HMAC
# migration. When set to "1", /api/telemetry/ingest and
# /api/billing/webhook/mercadopago will, on a primary canonical-form
# mismatch, RE-ATTEMPT verification under the legacy
# `JSON.stringify(req.body)` contract. Default OFF. Every successful
# legacy match emits a `*_hmac_legacy_fallback` warn log so operators
# can identify clients still on the old path. Remove once telemetry
# shows zero hits — DO NOT leave this on indefinitely (it defeats the
# cross-producer-portability fix this round shipped).
LEGACY_HMAC_FALLBACK=

# === SECTION: Billing — MercadoPago ===

# MercadoPago IPN HMAC secret (R18 R2). HMAC-SHA256 over the RFC 8785
# canonical-JSON body. Producers MUST canonicalise before signing (see
# src/server/middleware/canonicalBody.ts). MUST be at least 16 chars.
MP_IPN_SECRET=<paste-from-mercadopago-developer-panel>

# MP_OIDC_CLOCK_TOLERANCE_SEC: clock skew tolerance in seconds for JWT
# exp claim verification. Default 0 (strict). Set to 30-120 in
# environments with NTP drift. Higher values widen replay attack window.
MP_OIDC_CLOCK_TOLERANCE_SEC=

# === SECTION: Billing — Webpay / Transbank ===

# Webpay / Transbank — pasarela de pagos CL (web).
# Para DEV / CI / E2E: NO setear estas vars — el adapter usa por defecto
# las credenciales de "Tienda de Integración" embebidas en transbank-sdk
# (IntegrationCommerceCodes.WEBPAY_PLUS + IntegrationApiKeys.WEBPAY).
# Para PROD: aplicar a https://www.transbank.cl/ y poblar las 3 vars.
# Detalles + tarjetas de prueba: docs/runbooks/TRANSBANK_RUNBOOK.md
WEBPAY_COMMERCE_CODE=<commerce-code-from-transbank-portal>
WEBPAY_API_KEY=<api-key-from-transbank-portal>
WEBPAY_ENV=integration

# === SECTION: Billing — Khipu (optional) ===

# Khipu (CL — alternativa a Webpay para transferencias bancarias).
# DEV / CI: dejar en blanco — el adapter usa por defecto las credenciales
# de sandbox documentadas (KhipuAdapter.SANDBOX_DEFAULTS).
# PROD: aplicar a https://khipu.com/ y poblar las 3 vars.
KHIPU_RECEIVER_ID=<optional-receiver-id-from-khipu.com>
KHIPU_SECRET=<optional-secret-from-khipu.com>
KHIPU_ENV=integration

# === SECTION: Billing — Google Play ===

# Google Play Billing Integration.
# Package name of your Android app (e.g., com.praeventio.guard).
GOOGLE_PLAY_PACKAGE_NAME=<com.your.app.id>
# Full JSON string of the service account file from Google Cloud Console
# (Cloud Console → IAM → Service Accounts → Create key → JSON).
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=<paste-full-json-on-one-line>
# The Pub/Sub topic name for RTDN notifications.
GOOGLE_PLAY_RTDN_TOPIC=<projects/your-gcp/topics/play-rtdn>

# === SECTION: Sentry ===

# Sentry (error tracking + performance traces) — Phase 3 of master plan.
# Project "guardian-praeventio" in org "praeventio" (us region) is
# provisioned. Get the real DSN from
# https://praeventio.sentry.io/settings/projects/guardian-praeventio/keys/
# In prod, store both DSN values as Secret Manager secrets — do NOT
# commit a real .env.
# Backend (Node, server.ts → @sentry/node):
SENTRY_DSN=<paste-from-praeventio.sentry.io>
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development
# Frontend (Vite, src/lib/sentry.ts → @sentry/react). Same DSN, VITE_
# prefix required because Vite only exposes env vars whose names start
# with VITE_.
VITE_SENTRY_DSN=<paste-from-praeventio.sentry.io>
VITE_APP_VERSION=dev

# === SECTION: KMS ===

# KMS adapter selection. Allowed values: cloud-kms, in-memory-dev.
# Production MUST be `cloud-kms`. `in-memory-dev` boots with a warning
# and loses all KEK material on restart — useful only for local dev.
KMS_ADAPTER=in-memory-dev

# === SECTION: Photogrammetry — COLMAP CPU (optional) ===

# Photogrammetry worker (Cloud Run COLMAP CPU pipeline).
# Server-side ONLY. NEVER prefix with VITE_ — the token must not leak
# into the browser bundle. The API backend (Cloud Functions / Cloud Run
# app) reads these to call the worker via ColmapAdapter.fromEnv().
# When either is empty, DigitalTwinFaena falls back to the mock adapter
# and shows the "Vista previa" badge. Deploy guide:
#   docs/photogrammetry-deploy.md
PHOTOGRAMMETRY_WORKER_URL=<optional-https://colmap-worker-xyz.a.run.app>
PHOTOGRAMMETRY_WORKER_TOKEN=<optional-bearer-token>

# === SECTION: Photogrammetry — Modal GPU (optional) ===

# Photogrammetry GPU alternative (Modal.run + Meshroom).
# Server-side ONLY (do NOT prefix VITE_). Selected when the user picks
# "GPU rápido" in DigitalTwinFaena. Deploy guide:
#   docs/photogrammetry-modal.md  (run `modal deploy app.py` from
#   infra/modal-photogrammetry/, paste the URLs Modal prints below).
# When any of the three required vars is empty, ModalAdapter.fromEnv()
# returns null and the orchestrator falls back to ColmapAdapter or mock.
# MODAL_CANCEL_URL is optional — without it cancelJob is a client-side
# no-op (Modal cannot kill a running container after spawn anyway).
MODAL_SUBMIT_URL=<optional-https://...modal.run/submit>
MODAL_STATUS_URL=<optional-https://...modal.run/status>
MODAL_CANCEL_URL=<optional-https://...modal.run/cancel>
MODAL_TOKEN=<optional-modal-bearer-token>

# === SECTION: DWG converter (optional) ===

# Cloud function exposing LibreDWG / ODA File Converter for
# /api/cad/convert-dwg. Without these, the endpoint stays at 501 and
# AutoCADViewer falls back to DXF-only mode.
DWG_CONVERTER_URL=<optional-https://dwg-converter.a.run.app>
DWG_CONVERTER_TOKEN=<optional-bearer-token>

# === SECTION: SLM offline (optional) ===

# Feature flag for the offline Small Language Model (Brecha B). Allowed
# values: true, false. Default unset = false.
SLM_OFFLINE_ENABLED=false
