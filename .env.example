# Praeventio Guard — environment variable template.
#
# Copy this file to `.env.local` (gitignored) for development and to your
# secret manager (Cloud Run, GitHub Actions, etc.) for production.
#
# Run `npm run validate:env` BEFORE booting in production. The validator
# rejects placeholders and short secrets and points back here.
#
# For step-by-step "where do I get this value" instructions for every
# variable below, see: docs/runbooks/SECRETS_RUNBOOK.md
#
# Convention: `<...>` markers describe what the real value should look
# like. Anything matching `^(YOUR_|MY_|REPLACE_|PLACEHOLDER|<.*>)` is
# rejected by validate-env.cjs in prod mode.

# === SECTION: AI ===

# GEMINI_API_KEY: Required for Gemini AI API calls.
# Obtain at https://aistudio.google.com/app/apikey
# AI Studio also injects this at runtime from user secrets when the
# applet runs in Cloud Run.
GEMINI_API_KEY=<paste-from-aistudio.google.com/app/apikey>

# === SECTION: App URLs ===

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run
# service URL. Used for self-referential links, OAuth callbacks, billing
# returns and API endpoints.
APP_URL=<https://your-domain.com>

# APP_BASE_URL: Used to build Webpay return URL
# (`${APP_BASE_URL}/billing/webpay/return`).
# Dev: http://localhost:5173 (Vite). Prod: canonical app URL
# (https://app.praeventio.net).
APP_BASE_URL=<https://app.praeventio.net>

# === SECTION: Maps ===

# Google Maps JavaScript API key. Powers Site25DPanel + 4 emergency maps
# (SiteMap, Coastal/VolcanicEruptionMap, DynamicEvacuationMap).
# Restrict to your domain in console.cloud.google.com/apis/credentials.
VITE_GOOGLE_MAPS_API_KEY=<paste-from-console.cloud.google.com/apis/credentials>

# === SECTION: Auth (Google OAuth) ===

# Google Calendar + Fit OAuth credentials (Web application client).
# console.cloud.google.com → APIs & Services → Credentials → Create OAuth client.
GOOGLE_CLIENT_ID=<oauth-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<oauth-client-secret>

# === SECTION: Weather (optional) ===

# OpenWeatherMap API key — alternative to Open-Meteo (which requires no key).
# Open-Meteo is preferred; only set this if you need OWM features.
VITE_OPENWEATHER_API_KEY=<optional-paste-from-openweathermap.org>

# === SECTION: RAG / Pinecone (optional) ===

# Pinecone vector DB for RAG over BCN normativa. Without this, RAG falls
# back to in-memory mode (degraded but functional).
PINECONE_API_KEY=<optional-paste-from-app.pinecone.io>
PINECONE_INDEX_NAME=praeventio-guard

# === SECTION: Push Notifications ===

# Firebase Cloud Messaging Web Push VAPID public key.
# Firebase Console → Project settings → Cloud Messaging → Web configuration.
VITE_FIREBASE_VAPID_KEY=<paste-vapid-public-key-from-firebase-console>

# === SECTION: Server secrets ===

# express-session signing secret. MUST be at least 32 chars.
# Generate with: `openssl rand -hex 32`
SESSION_SECRET=<openssl-rand-hex-32>

# OPTIONAL — dedicated pepper for the culture-pulse responder hash
# (worker-survey anonymity, Ley Karín 21.643 / Ley 19.628). Keys the HMAC that
# anonymizes survey responders so a privileged insider with DB read + the uid
# roster cannot re-identify who answered what. If unset, the hash falls back to
# SESSION_SECRET — set this only when you want key-separation. MUST be >= 32 chars.
# Generate with: `openssl rand -hex 32`
# CULTURE_PULSE_PEPPER=<openssl-rand-hex-32>

# IoT telemetry HMAC secret. MUST be at least 32 chars.
# Generate with: `openssl rand -hex 32`
# Used to verify HMAC-SHA256 on /api/telemetry/ingest (canonical-JSON
# body, see src/server/middleware/canonicalBody.ts).
IOT_WEBHOOK_SECRET=<openssl-rand-hex-32>

# === SECTION: Legacy / migration flags ===

# Round 18 R6 — emergency rollback for the canonical-JSON HMAC
# migration. When set to "1", /api/telemetry/ingest and
# /api/billing/webhook/mercadopago will, on a primary canonical-form
# mismatch, RE-ATTEMPT verification under the legacy
# `JSON.stringify(req.body)` contract. Default OFF. Every successful
# legacy match emits a `*_hmac_legacy_fallback` warn log so operators
# can identify clients still on the old path. Remove once telemetry
# shows zero hits — DO NOT leave this on indefinitely (it defeats the
# cross-producer-portability fix this round shipped).
LEGACY_HMAC_FALLBACK=

# === SECTION: Billing — MercadoPago ===

# MercadoPago IPN HMAC secret (R18 R2). HMAC-SHA256 over the RFC 8785
# canonical-JSON body. Producers MUST canonicalise before signing (see
# src/server/middleware/canonicalBody.ts). MUST be at least 16 chars.
MP_IPN_SECRET=<paste-from-mercadopago-developer-panel>

# MP_OIDC_CLOCK_TOLERANCE_SEC: clock skew tolerance in seconds for JWT
# exp claim verification. Default 0 (strict). Set to 30-120 in
# environments with NTP drift. Higher values widen replay attack window.
MP_OIDC_CLOCK_TOLERANCE_SEC=

# === SECTION: Billing — Webpay / Transbank ===

# Webpay / Transbank — pasarela de pagos CL (web).
# Para DEV / CI / E2E: NO setear estas vars — el adapter usa por defecto
# las credenciales de "Tienda de Integración" embebidas en transbank-sdk
# (IntegrationCommerceCodes.WEBPAY_PLUS + IntegrationApiKeys.WEBPAY).
# Para PROD: aplicar a https://www.transbank.cl/ y poblar las 3 vars.
# Detalles + tarjetas de prueba: docs/runbooks/TRANSBANK_RUNBOOK.md
WEBPAY_COMMERCE_CODE=<commerce-code-from-transbank-portal>
WEBPAY_API_KEY=<api-key-from-transbank-portal>
WEBPAY_ENV=integration

# === SECTION: Billing — Khipu (optional) ===

# Khipu (CL — alternativa a Webpay para transferencias bancarias).
# DEV / CI: dejar en blanco — el adapter usa por defecto las credenciales
# de sandbox documentadas (KhipuAdapter.SANDBOX_DEFAULTS).
# PROD: aplicar a https://khipu.com/ y poblar las 3 vars.
KHIPU_RECEIVER_ID=<optional-receiver-id-from-khipu.com>
KHIPU_SECRET=<optional-secret-from-khipu.com>
KHIPU_ENV=integration

# === SECTION: Billing — Google Play ===

# Google Play Billing Integration.
# Package name of your Android app (e.g., com.praeventio.guard).
GOOGLE_PLAY_PACKAGE_NAME=<com.your.app.id>
# Full JSON string of the service account file from Google Cloud Console
# (Cloud Console → IAM → Service Accounts → Create key → JSON).
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=<paste-full-json-on-one-line>
# The Pub/Sub topic name for RTDN notifications.
GOOGLE_PLAY_RTDN_TOPIC=<projects/your-gcp/topics/play-rtdn>

# === SECTION: Sentry ===

# Sentry (error tracking + performance traces) — Phase 3 of master plan.
# Project "guardian-praeventio" in org "praeventio" (us region) is
# provisioned. Get the real DSN from
# https://praeventio.sentry.io/settings/projects/guardian-praeventio/keys/
# In prod, store both DSN values as Secret Manager secrets — do NOT
# commit a real .env.
# Backend (Node, server.ts → @sentry/node):
SENTRY_DSN=<paste-from-praeventio.sentry.io>
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development
# Frontend (Vite, src/lib/sentry.ts → @sentry/react). Same DSN, VITE_
# prefix required because Vite only exposes env vars whose names start
# with VITE_.
VITE_SENTRY_DSN=<paste-from-praeventio.sentry.io>
VITE_APP_VERSION=dev

# VITE_DEMO_MODE: activa "demo blocks" sintéticos en pantallas como
# Attendance (worker.name = "Demo Block …" fuerza bloqueo de acceso).
# Solo surte efecto cuando `import.meta.env.DEV === true`; en builds
# de producción el flag se ignora aunque venga 'true'. Default 'false'.
VITE_DEMO_MODE=false

# === SECTION: KMS ===

# KMS adapter selection. Allowed values: cloud-kms, in-memory-dev.
# Production MUST be `cloud-kms`. `in-memory-dev` boots with a warning
# and loses all KEK material on restart — useful only for local dev.
KMS_ADAPTER=in-memory-dev

# === SECTION: Photogrammetry — COLMAP CPU (optional) ===

# Photogrammetry worker (Cloud Run COLMAP CPU pipeline).
# Server-side ONLY. NEVER prefix with VITE_ — the token must not leak
# into the browser bundle. The API backend (Cloud Functions / Cloud Run
# app) reads these to call the worker via ColmapAdapter.fromEnv().
# When either is empty, DigitalTwinFaena falls back to the mock adapter
# and shows the "Vista previa" badge. Deploy guide:
#   docs/photogrammetry-deploy.md
PHOTOGRAMMETRY_WORKER_URL=<optional-https://colmap-worker-xyz.a.run.app>
PHOTOGRAMMETRY_WORKER_TOKEN=<optional-bearer-token>

# === SECTION: Photogrammetry — Modal GPU (optional) ===

# Photogrammetry GPU alternative (Modal.run + Meshroom).
# Server-side ONLY (do NOT prefix VITE_). Selected when the user picks
# "GPU rápido" in DigitalTwinFaena. Deploy guide:
#   docs/photogrammetry-modal.md  (run `modal deploy app.py` from
#   infra/modal-photogrammetry/, paste the URLs Modal prints below).
# When any of the three required vars is empty, ModalAdapter.fromEnv()
# returns null and the orchestrator falls back to ColmapAdapter or mock.
# MODAL_CANCEL_URL is optional — without it cancelJob is a client-side
# no-op (Modal cannot kill a running container after spawn anyway).
MODAL_SUBMIT_URL=<optional-https://...modal.run/submit>
MODAL_STATUS_URL=<optional-https://...modal.run/status>
MODAL_CANCEL_URL=<optional-https://...modal.run/cancel>
MODAL_TOKEN=<optional-modal-bearer-token>

# === SECTION: DWG converter (optional) ===

# Sprint 21 Bucket Q — DWG converter (LibreDWG GPL-3.0 in isolated Cloud Run
# service; HTTP boundary keeps GPL contamination scoped to the converter
# image — see ADR 0008). The main app proxies /api/cad/convert-dwg to this
# service; if any of the three vars below are unset the route returns 503
# `dwg_converter_not_configured` so health checks can detect mis-config.
DWG_CONVERTER_URL=<optional-https://dwg-converter.a.run.app>
DWG_CONVERTER_TOKEN=<optional-bearer-token>
CAD_OUTPUT_BUCKET=praeventio-cad

# Sprint 23 Bucket EE — USDZ converter (Pixar OpenUSD in isolated Cloud
# Run service; .glb -> .usdz for iOS AR Quick Look. Apple usdzconvert is
# macOS-only, so we ship a Linux container that builds OpenUSD v24.05.
# See docs/usdz-converter-deploy.md). The build script
# scripts/generate-ar-usdz.mjs and any runtime caller obtain a configured
# adapter via UsdzConverter.fromEnv() — null when these vars are unset.
USDZ_CONVERTER_URL=<optional-https://usdz-converter.a.run.app>
USDZ_CONVERTER_TOKEN=<optional-bearer-token>
USDZ_STAGING_BUCKET=praeventio-ar-usdz

# === SECTION: SLM offline (optional) ===

# Feature flag for the offline Small Language Model (Brecha B). Allowed
# values: true, false. B14 (2026-06-11): default unset = TRUE — the
# on-device SLM (Qwen 0.5B pre-packaged) is ON by default. Set to
# `false` ONLY as an emergency kill-switch (disables on-device AI; the
# resilient ladder still serves RAG corpus + honest fallback).
SLM_OFFLINE_ENABLED=true

# === SECTION: DTE / SII (factura electrónica Chile) ===

# Sprint 23 Bucket GG — Bsale-backed Documento Tributario Electrónico (DTE)
# emission. See docs/dte-sii.md for the full setup runbook (Bsale account,
# certificado digital, autorización SII, CAF folio ranges).
#
# When BOTH BSALE_ACCESS_TOKEN and BSALE_OFFICE_ID are unset, the
# /api/dte/* routes return 503 `dte_not_configured` and the auto-issue path
# in invoice closure becomes a no-op. Production deploys MUST set both.
BSALE_ACCESS_TOKEN=<bsale-static-access-token>
BSALE_OFFICE_ID=<numeric-bsale-office-id>
# Optional override for SII certification; defaults to https://api.bsale.io/v1.
BSALE_API_BASE_URL=

# Auto-emite el DTE cuando el invoice transiciona a `status: 'paid'`.
# Allowed values: true, false. Default unset = false (manual emission via
# the admin endpoint POST /api/dte/create).
DTE_AUTO_ISSUE=true

# Optional alternate PSE selector. `bsale` (default) | `openfactura` |
# `simpleapi` | `libredte` | `noop`. Most deployments leave this unset and
# let the env vars above decide. See src/services/sii/index.ts.
SII_PSE=bsale

# ─────────────────────────────────────────────────────────────────────
# Sprint E backend debt — env vars documentation sweep (2026-05-16)
#
# Las siguientes vars existían en el código pero NO estaban en este
# template. Documentadas ahora para evitar drift entre código y
# scripts/validate-env.cjs. Agrupadas por dominio.
# ─────────────────────────────────────────────────────────────────────

# === SECTION: Node / Runtime metadata ===

# NODE_ENV: 'production' | 'development' | 'test'. Default: development.
# El validador en scripts/validate-env.cjs y muchas guardas de seguridad
# (KMS preflight, B2D salt fail-closed, CSP estricta) gating por
# NODE_ENV === 'production'.
NODE_ENV=development

# PORT: puerto Express. Default 8080 (matchea Cloud Run default).
# Override solo si corres múltiples instancias locales.
PORT=8080

# TRUST_PROXY_HOPS: cantidad exacta de proxies confiables delante de Express.
# Default: 1 cuando Cloud Run inyecta K_SERVICE; deshabilitado fuera de Cloud Run.
# OMITIR la variable para usar el default. No dejarla vacía: el arranque la
# rechaza. No aumentar sin verificar X-Forwarded-For en staging; un valor
# excesivo permite que el cliente elija la IP usada por el rate limiter.
# TRUST_PROXY_HOPS=1

# NO_COLOR: si está set a cualquier valor truthy, desactiva colores en
# los logs de logger. Útil para CI o terminales sin TTY.
NO_COLOR=

# Auto-inyectadas por Cloud Run — NO setear manual en dev:
#   HOSTNAME              — hostname del contenedor (debug only)
#   K_REVISION            — Cloud Run revision id (audit trail)
#   GIT_COMMIT            — git SHA del build (set en CI build step)
#   CLOUD_RUN_REGION      — region del servicio
#   CLOUD_RUN_SERVICE     — nombre del servicio
#   GOOGLE_CLOUD_PROJECT  — alias auto-injected de GCP project
#   K_SERVICE             — alias Cloud Run service (legacy)

# === SECTION: Firebase + GCP project ids ===

# FIREBASE_PROJECT_ID: usado por server-side Admin SDK boot cuando no
# se provee GOOGLE_APPLICATION_CREDENTIALS. Suele auto-detectarse en
# Cloud Run; setear explícito en dev si admin.initializeApp() falla.
FIREBASE_PROJECT_ID=<praeventio-prod>

# GCP_PROJECT_ID: alias canónico — algunos adapters (Vertex, Storage,
# Pub/Sub) prefieren este; otros usan FIREBASE_PROJECT_ID. Setear ambos
# al mismo valor para evitar drift.
GCP_PROJECT_ID=<praeventio-prod>

# GOOGLE_APPLICATION_CREDENTIALS: path al JSON de service account.
# SOLO necesario en dev local (Cloud Run lo inyecta automáticamente
# vía workload identity). Path absoluto recomendado.
GOOGLE_APPLICATION_CREDENTIALS=

# === SECTION: KMS + Security ===

# KMS_KEY_RESOURCE_NAME: full resource path del Cloud KMS CryptoKey
# usado para envelope encryption (DEKs cifrados con KEK Cloud KMS).
# Formato: projects/.../locations/.../keyRings/.../cryptoKeys/...
# REQUIRED en prod cuando KMS_ADAPTER=cloud-kms. El KMS preflight en
# server.ts falla closed (exit 1) si falta.
KMS_KEY_RESOURCE_NAME=<projects/X/locations/Y/keyRings/Z/cryptoKeys/W>

# Firma regulatoria SUSESO / DS-67 / DS-76. Habilitar solo cuando existe
# una CryptoKey ASYMMETRIC_SIGN RSA_SIGN_PSS_*_SHA256 y el caller OIDC está
# fijado. El servidor firma el PDF exacto y verifica localmente el resultado.
COMPLIANCE_KMS_SIGNING_ENABLED=false
COMPLIANCE_KMS_SIGNING_KEY_VERSION=<projects/X/locations/Y/keyRings/Z/cryptoKeys/regulatory-signing/cryptoKeyVersions/1>
COMPLIANCE_KMS_CALLER_SERVICE_ACCOUNT=<regulatory-signer@PROJECT_ID.iam.gserviceaccount.com>
COMPLIANCE_KMS_SIGNER_UID=<compliance-kms>
COMPLIANCE_KMS_SIGNER_RUT=<12.345.678-5>
# Opcional si APP_BASE_URL ya es la audiencia exacta usada al acuñar el token.
COMPLIANCE_KMS_OIDC_AUDIENCE=<https://app.praeventio.net>

# B2D_API_KEY_SALT: salt para hash de B2D API keys (sprint E security
# fix #272). Mínimo 16 chars, único por deployment. NUNCA usar el
# default 'praeventio-b2d-default-salt' en prod.
B2D_API_KEY_SALT=<random-base64-32-bytes>

# B2D_FREE_CAP: límite de requests/30d para tier free B2D. Default 1000.
B2D_FREE_CAP=1000

# PRAEVENTIO_FORCE_IA_FS_STORE: fuerza el store Firestore (compartido entre
# pods) de los rate-limiters IA (geminiLimiter / b2dFreeLimiter /
# geminiGlobalDailyLimiter) fuera de prod. En prod el store Firestore se
# activa SIEMPRE (NODE_ENV=production lo garantiza, ver
# src/server/middleware/limiters.ts:makeIaRateLimitStore); este flag solo
# existe para pinear esa inyección en tests sin levantar NODE_ENV=production.
# Sin él (y sin prod) los limiters caen al MemoryStore default, que es
# PER-POD — correcto para dev single-process, inseguro multi-réplica. Valores:
# '1' = forzar Firestore; vacío/ausente = MemoryStore (default dev).
PRAEVENTIO_FORCE_IA_FS_STORE=

# WEBAUTHN_RP_ID: RP id usado por WebAuthn (debe coincidir con dominio
# canónico app: 'praeventio.net' o 'localhost' en dev).
WEBAUTHN_RP_ID=praeventio.net

# SCHEDULER_SHARED_SECRET: shared secret para validar requests de
# Cloud Scheduler a /api/maintenance/* y /api/admin/jobs/*. El middleware
# verifySchedulerToken lo compara (constant-time) con el header
# `Authorization: Bearer <secret>`. Útil para replays manuales de ops.
# Rotar cada 90d. En producción el camino normal es OIDC (abajo); este
# secret es el fallback y NO es obligatorio si SCHEDULER_SERVICE_ACCOUNT
# está seteado.
SCHEDULER_SHARED_SECRET=<random-base64-32-bytes>

# SCHEDULER_SERVICE_ACCOUNT: email EXACTO de la service account con la que
# Cloud Scheduler firma sus tokens OIDC (deploy.yml provisiona los jobs con
# --oidc-service-account-email=climate-scan-sa@<PROJECT>.iam.gserviceaccount.com).
# verifySchedulerToken acepta un token OIDC de Google SOLO si su claim `email`
# coincide con este valor (anti-spoof: cualquier SA de cualquier proyecto GCP
# puede mintar un OIDC, así que el match exacto del email es lo que lo hace
# seguro). Si no se setea, se deriva climate-scan-sa@${GOOGLE_CLOUD_PROJECT}.
# SCHEDULER_OIDC_AUDIENCE (opcional): audiencia esperada del token; por
# defecto se deriva del host de la request (la URL de Cloud Run que el
# scheduler ya usa como --oidc-token-audience).
SCHEDULER_SERVICE_ACCOUNT=climate-scan-sa@<PROJECT_ID>.iam.gserviceaccount.com

# === SECTION: AI adapters + residency ===

# AI_ADAPTER: 'gemini' (default) | 'vertex' | 'noop'. Selecciona qué
# adapter usa AskGuardian + Asesor chat. 'vertex' requiere
# VERTEX_PROJECT_ID + VERTEX_LOCATION.
AI_ADAPTER=gemini

# AI_RESIDENCY_STRICT: si está set a 'true', rechaza llamadas IA que
# violen residencia geográfica (PIPL CN, 152-FZ RU, PIPA TW, GDPR EU).
# Default false en dev, set a true en deployments con tenant CN/RU/TW.
AI_RESIDENCY_STRICT=false

# AI_ROUTE_LATAM_TO_VERTEX: si está 'true' Y AI_ADAPTER=gemini, los
# tenants LATAM (CL/MX/AR/PE/BR/CO) se rutean a Vertex AI en us-east4
# para mejor latencia. Default false.
AI_ROUTE_LATAM_TO_VERTEX=false

# VERTEX_PROJECT_ID / VERTEX_REGION / VERTEX_LOCATION: configuración
# Vertex AI cuando AI_ADAPTER=vertex. Region es alias de location.
# Timeout en ms — default 30000.
VERTEX_PROJECT_ID=
VERTEX_REGION=us-central1
VERTEX_LOCATION=us-central1
VERTEX_TIMEOUT_MS=30000

# VERTEX_TRAINING_ENABLED: gate del trainer (vertexTrainer.ts). Default
# false — el trainer está descartado por directiva usuario (solo
# tier mega-enterprise; ver memoria product_b2d_api_model).
VERTEX_TRAINING_ENABLED=false

# BIGQUERY_TRAINING_DATASET: dataset destino del trainer cuando se
# habilite (futuro). Setear NO activa nada solo — necesita
# VERTEX_TRAINING_ENABLED=true.
BIGQUERY_TRAINING_DATASET=

# GEMINI_DAILY_GLOBAL_CAP: global cross-user daily cap en req/24h para
# /api/gemini + /api/ask-guardian. Default 1000. Mounted before el
# per-uid limiter en limiters.ts.
GEMINI_DAILY_GLOBAL_CAP=1000

# AI_MODEL_*: OPTIONAL per-use-case model overrides (debt D6). Registry
# central: src/config/aiModels.ts (leer su doc-comment antes de tocar).
# Dejar vacío = default de cada caso de uso. Útil para rotar de modelo
# sin deploy cuando Google depreca un SKU. Si se apunta a un SKU sin
# entrada en la tabla de pricing (src/services/gemini/governance.ts), el
# costeo cae a Pro pricing (sobre-cobra, nunca sub-cobra).
# AI_MODEL_CHAT: chat conversacional/streaming (default gemini-3.1-pro-preview)
# AI_MODEL_REASONING: análisis profundo/planes (default gemini-3.1-pro-preview)
# AI_MODEL_FAST: clasificación/extracción rápida (default gemini-3-flash-preview)
# AI_MODEL_FAST_STABLE: JSON rápido en SKU estable (default gemini-2.0-flash)
# AI_MODEL_FAST_LONGFORM: reportes Markdown largos (default gemini-3.1-flash-preview)
# AI_MODEL_LITE: mínima latencia con fallback local (default gemini-1.5-flash)
# AI_MODEL_VISION: análisis de imagen (default gemini-3.1-pro-preview)
# AI_MODEL_VISION_FAST: detección EPP rápida (default gemini-3.1-flash-image-preview)
# AI_MODEL_IMAGE_GENERATION: generación de imagen (default gemini-2.0-flash-preview-image-generation)
# AI_MODEL_TTS: text-to-speech (default gemini-2.5-flash-preview-tts)
# AI_MODEL_EMBEDDINGS: embeddings RAG (default text-embedding-004)
AI_MODEL_CHAT=
AI_MODEL_REASONING=
AI_MODEL_FAST=
AI_MODEL_FAST_STABLE=
AI_MODEL_FAST_LONGFORM=
AI_MODEL_LITE=
AI_MODEL_VISION=
AI_MODEL_VISION_FAST=
AI_MODEL_IMAGE_GENERATION=
AI_MODEL_TTS=
AI_MODEL_EMBEDDINGS=

# --- Self-hosted AI provider (OPCIONAL — independencia de cuotas Gemini) ---
# Capa de proveedor por acción: cada acción whitelisteada de /api/gemini puede
# enrutar a un endpoint LLM SELF-HOSTED OpenAI-compatible (vLLM u Ollama
# sirviendo Xiaomi MiMo-7B, Qwen, o cualquier modelo open-weights) en vez de
# Gemini. Runbook operacional: docs/runbooks/SELFHOSTED_AI.md.
#
# REGLA CLAVE: con AI_SELFHOSTED_BASE_URL/AI_SELFHOSTED_MODEL AUSENTES la
# feature está LIMPIAMENTE APAGADA — todo va a Gemini exactamente como hoy
# (byte-identical). Nada se simula ni degrada. Rollback = borrar estas vars.
#
# AI_SELFHOSTED_BASE_URL: endpoint OpenAI-compatible. Se acepta con o sin el
#   sufijo /v1 (se normaliza). Debe empezar con http(s)://.
#   Ollama local:  http://localhost:11434/v1
#   vLLM interno:  http://vllm.internal:8000/v1
AI_SELFHOSTED_BASE_URL=
# AI_SELFHOSTED_API_KEY: Bearer token OPCIONAL (Ollama no necesita ninguno;
#   vLLM solo si se lanzó con --api-key).
AI_SELFHOSTED_API_KEY=
# AI_SELFHOSTED_MODEL: nombre del modelo servido. Requerido si hay BASE_URL.
#   Ollama: el tag del `ollama pull` (p.ej. mimo-7b, qwen2.5:7b)
#   vLLM:   el id servido (p.ej. XiaomiMiMo/MiMo-7B-RL)
AI_SELFHOSTED_MODEL=
# AI_SELFHOSTED_TIMEOUT_MS: timeout por llamada (default 30000).
AI_SELFHOSTED_TIMEOUT_MS=
# AI_PROVIDER_DEFAULT: proveedor para acciones NO listadas abajo.
#   'gemini' (default) | 'selfhosted'. Recomendado: dejar 'gemini' y migrar
#   acción por acción vía AI_PROVIDER_ACTIONS_SELFHOSTED.
AI_PROVIDER_DEFAULT=
# AI_PROVIDER_ACTIONS_SELFHOSTED: lista separada por comas de acciones que
#   van al endpoint self-hosted (p.ej. getChatResponse,queryBCN,getSafetyAdvice).
#   Solo acciones con spec en src/services/ai/selfHostedActions.ts se sirven
#   self-hosted; el resto sigue en Gemini aunque estén listadas.
AI_PROVIDER_ACTIONS_SELFHOSTED=
# AI_PROVIDER_ACTIONS_GEMINI: escape hatch — acciones forzadas a Gemini
#   incluso con AI_PROVIDER_DEFAULT=selfhosted. Gana sobre la lista anterior.
AI_PROVIDER_ACTIONS_GEMINI=
# AI_SELFHOSTED_FALLBACK_GEMINI: si una llamada self-hosted falla, ¿reintentar
#   en Gemini antes de la escalera degradada (RAG → canned)? '1' default; '0'
#   = saltar Gemini e ir directo a la escalera.
AI_SELFHOSTED_FALLBACK_GEMINI=

# === SECTION: Billing — Mercado Pago + Apple/Google IAP ===

# MP_ACCESS_TOKEN: Mercado Pago access token. Server-side only.
# Doc runbook: docs/runbooks/MERCADOPAGO_RUNBOOK.md
MP_ACCESS_TOKEN=

# MP_ENV: 'sandbox' (default dev) | 'prod'. Toggles entre URLs sandbox
# y producción de Mercado Pago. Validador valida coherencia con
# MP_ACCESS_TOKEN (prefijo TEST- vs APP-).
MP_ENV=sandbox

# MP_JWKS_URL / MP_OIDC_AUDIENCE / MP_OIDC_ISSUER: validación OIDC del
# webhook IPN Mercado Pago (validación firma JWT cross-tenant).
MP_JWKS_URL=
MP_OIDC_AUDIENCE=
MP_OIDC_ISSUER=

# Apple App Store Server API — para validación de IAP iOS.
# Obtenibles en App Store Connect / Users & Access / Keys.
APPLE_API_KEY_PATH=
APPLE_KEY_ID=
APPLE_ISSUER_ID=
APPLE_BUNDLE_ID=
# Android Play package name — usado en validator googlePlayValidator.ts
ANDROID_PACKAGE_NAME=net.praeventio.guard
# Permite acceso a test purchases en sandbox Google Play (auto true en
# NODE_ENV=development).
GOOGLE_PLAY_ALLOW_TEST_PURCHASES=false

# Razón social del emisor (DTE/factura). Setear en prod.
BILLING_EMISOR_RAZON_SOCIAL=<Razon Social SpA>

# === SECTION: DTE alternate PSEs (futuro) ===

# Adapters alternos al default Bsale — stubs honestos que tiran
# NotImplementedError hasta que el equipo wire el adapter real.
LIBREDTE_BASE_URL=
LIBREDTE_TOKEN=
OPENFACTURA_API_KEY=
SIMPLEAPI_API_KEY=

# === SECTION: External APIs + datasets ===

# OPENWEATHER_API_KEY: backup climate adapter cuando NASA POWER no
# está disponible. Default deshabilitado — el adapter usa NASA POWER
# (free, sin key) primario.
OPENWEATHER_API_KEY=

# RESEND_API_KEY: Resend.com — emails transaccionales (welcome,
# password reset, billing invoice). Server-side only.
RESEND_API_KEY=

# PINECONE_ENDPOINT + PINECONE_INDEX: vector DB para RAG sobre
# incidentes. Server-side. Si vacíos, el RAG cae a Firestore-only
# (más lento pero funciona).
PINECONE_ENDPOINT=
PINECONE_INDEX=

# === SECTION: IoT broker (puente MQTT → telemetry_events) ===
#
# Contrato vigente (claude/mqtt-wire, 2026-06): el puente se activa con
# MQTT_BROKER_URL. Si está VACÍO/ausente, el bridge queda limpiamente
# APAGADO (sin intentos de conexión; un solo log al boot). Los sensores
# industriales de gas/atmósfera publican en
#   [MQTT_TOPIC_PREFIX/]tenants/{tenantId}/projects/{projectId}/devices/{deviceId}/telemetry
# y SOLO se aceptan lecturas de devices enrolados vía
# POST /api/iot/devices/register (status 'active' y projectId del tópico).
# Las lecturas aceptadas caen en la MISMA colección `telemetry_events` que
# el ingest HMAC, por lo que el gas-gate de permisos de espacio confinado
# las consume transparentemente. Ver src/server/triggers/mqttTelemetryBridge.ts.

# MQTT_BROKER_URL: mqtt:// | mqtts:// | ws:// | wss://. El broker DEBE
# exigir autenticación de publishers (sin publish anónimo) — es la capa
# de transporte del modelo de confianza (ADR 0015).
MQTT_BROKER_URL=

# Credenciales del broker (opcionales según el broker).
MQTT_USERNAME=
MQTT_PASSWORD=

# Namespace de tópicos en el broker (opcional, sin slashes al borde).
# Ej: 'praeventio/prod'.
MQTT_TOPIC_PREFIX=

# mTLS opcional (strings PEM) para brokers self-hosted (EMQX/Mosquitto).
MQTT_TLS_CA=
MQTT_TLS_CERT=
MQTT_TLS_KEY=

# Client id estable (opcional; por defecto se genera uno aleatorio por boot).
MQTT_CLIENT_ID=

# --- Contrato LEGACY (Sprint 32 TT) — honrado solo si MQTT_BROKER_URL está vacío ---
# IOT_BROKER_ENABLED: '1' activa el adapter legacy. Cualquier otro valor lo apaga.
IOT_BROKER_ENABLED=
# IOT_BROKER_ADAPTER: 'memory' (bus en proceso, dev/tests) | 'emqx' (usa
# IOT_EMQX_*). 'cloud'/'gcp' fue SUPERSEDIDO: Google retiró Cloud IoT Core
# en 2023 — el boot lo rechaza con log de migración (usar MQTT_BROKER_URL).
IOT_BROKER_ADAPTER=memory
IOT_EMQX_URL=
IOT_EMQX_CA=
IOT_EMQX_CERT=
IOT_EMQX_KEY=

# === SECTION: Observability — Sentry + Otel + Prometheus ===

# SENTRY_API_TOKEN: per-organization API token para rotación de DSNs
# vía script. NO es el DSN público; ese se setea en VITE_SENTRY_DSN.
SENTRY_API_TOKEN=
SENTRY_ORG=praeventio
SENTRY_PROJECT_ID=

# ERROR_TRACKER: 'sentry' (default) | 'noop' | 'console'. Override
# para forzar fallback cuando Sentry esté caído.
ERROR_TRACKER=sentry

# METRICS_ADAPTER: 'prometheus' (default) | 'noop'. Si 'prometheus',
# expone /metrics endpoint. Server.ts gating por PROMETHEUS_ENABLED.
METRICS_ADAPTER=prometheus
PROMETHEUS_ENABLED=true

# OpenTelemetry — opcional, deshabilitado por default. Setear endpoint
# habilita traces export.
OTEL_TRACES_EXPORTER=
OTEL_EXPORTER_OTLP_ENDPOINT=

# HEALTH_DEEP_URL: URL self-check usada por el cron resilienceHealth
# (default $APP_URL/api/health). Override solo si el health endpoint
# vive en otro host.
HEALTH_DEEP_URL=

# === SECTION: Mobile signing + assetlinks ===

# ANDROID_CERT_SHA256: SHA-256 del cert de firma Play (32 bytes hex con ':',
# ej. 3D:AC:D9:...:A0). Lo usa scripts/render-well-known.mjs (corre en `prebuild`)
# para generar public/.well-known/assetlinks.json (Android App Links). NO hay
# fallback hardcodeado: un valor PRESENTE pero placeholder/malformado ABORTA el
# build (un fingerprint equivocado rompe App Links o valida la app contra un cert
# ajeno). AUSENTE: assetlinks.json queda con fingerprints vacíos (honesto, App
# Links no valida) + warning — así los builds web/dev/CI no requieren el keystore.
# Obtenlo con:
#   keytool -list -v -keystore <release.jks> -alias <alias> | grep SHA256
# (o usa scripts/fill-android-assetlinks.mjs que lo extrae vía keytool).
ANDROID_CERT_SHA256=

# REQUIRE_ANDROID_CERT: '1'/'true' en un build de RELEASE/deploy (Cloud Build,
# release Android) → render-well-known.mjs falla closed (aborta) si falta
# ANDROID_CERT_SHA256, para no publicar nunca sin el cert real. OPCIONAL — sin
# definir, ausente sólo emite warning (no aborta). Déjalo vacío en dev/CI.
REQUIRE_ANDROID_CERT=

# APPLE_TEAM_ID: Apple Developer Team ID (10 chars). OPCIONAL — sin él,
# render-well-known.mjs deja apple-app-site-association con "TEAMID" honesto +
# warning (iOS deploy bloqueado por Apple Developer Account de todas formas).
APPLE_TEAM_ID=

# SECURITY_CONTACT_EMAIL: contacto RFC 9116 para security.txt.
# Default: contacto@praeventio.net.
SECURITY_CONTACT_EMAIL=

# APP_VERSION: versión semántica de la build móvil. Inyectada en
# Sentry releases + about page. Default lee de package.json en build.
APP_VERSION=

# === SECTION: Photogrammetry + ML pipelines ===

# PHOTOGRAMMETRY_OUTPUT_BUCKET: GCS bucket donde el job COLMAP escribe
# los .glb/.usdz resultantes. REQUIRED si IOT_BROKER_ENABLED=true Y
# se usa /api/photogrammetry.
PHOTOGRAMMETRY_OUTPUT_BUCKET=

# CRITICAL_REPLICA_BUCKET / GCS_BACKUP_BUCKET / GCS_RESTORE_PATH:
# infraestructura del cron firestoreCriticalReplicate (Sprint 41).
# Vacíos = job no-op (no replica nada). Setear en prod para enable.
CRITICAL_REPLICA_BUCKET=
GCS_BACKUP_BUCKET=
GCS_RESTORE_PATH=
BACKUP_MAX_AGE_HOURS=48

# DR_TEST_PROJECT_ID: GCP project usado para Disaster Recovery tests
# (restore en project secundario sin afectar prod). Solo CI.
DR_TEST_PROJECT_ID=

# === SECTION: ERP + analytics ===

# ERP_ADAPTER: 'mock' (default dev) | 'sap' | 'oracle' | 'odoo'.
# Los productivos son stubs honestos pendientes de implementación.
ERP_ADAPTER=mock

# ANALYTICS_OPT_OUT: si 'true', deshabilita el envío de analytics
# events a Sentry/PostHog. Honra preferencia del usuario.
ANALYTICS_OPT_OUT=false

# ENV_CONTEXT_ENABLED: si 'true' (default), inyecta el environmental
# context global cada 10 min en el polling cron (server.ts).
ENV_CONTEXT_ENABLED=true

# PUBLIC_API_BASE_URL: URL base pública (sin auth) — usada por feed
# RSS / OpenAPI viewer. Default = APP_BASE_URL.
PUBLIC_API_BASE_URL=

# OAUTH_ENVELOPE_ENABLED: si 'true', cifra OAuth refresh tokens con
# DEK envelope antes de persistir. Default true en prod (Sprint 39).
OAUTH_ENVELOPE_ENABLED=true

# === SECTION: E2E + tests ===

# E2E_MODE: si 'true', activa el endpoint /api/test/seed para
# Playwright + relaja gates de auth. NUNCA setear en prod.
E2E_MODE=false

# E2E_TEST_SECRET: shared secret para autorizar los seeders E2E.
# Solo necesario cuando E2E_MODE=true.
E2E_TEST_SECRET=

# === SECTION: Misc — pending audits ===

# WEBAUTHN_RP_NAME: nombre humano del Relying Party que el navegador
# muestra durante la ceremonia WebAuthn. Default 'Praeventio Guard'.
WEBAUTHN_RP_NAME=Praeventio Guard

# WEBHOOK_SECRET: shared secret en query string `?token=` del Pub/Sub
# webhook Google Play RTDN. Diferente de IOT_WEBHOOK_SECRET (telemetría
# IoT). Rotar cada 90d.
WEBHOOK_SECRET=<random-base64-32-bytes>

# WEBPAY_ENVIRONMENT: 'production' (default) | 'integration'. Toggle del
# adapter Transbank Webpay entre URLs sandbox vs prod.
WEBPAY_ENVIRONMENT=integration

# WEBP_QUALITY: calidad JPEG → WebP en scripts/convert-to-webp.mjs.
# Default 85 (balance tamaño / calidad).
WEBP_QUALITY=85

# ─────────────────────────────────────────────────────────────────────
# Infra cleanup tail (2026-05-17) — env vars detectados en código pero
# no documentados antes. Mantengamos paridad código ↔ .env.example.
# ─────────────────────────────────────────────────────────────────────

# === SECTION: Health vault + secrets adicionales ===

# CONFIDENTIAL_REPORTS_SALT: salt usado por confidentialReports endpoint
# para hashear identificadores (server/routes/sprintK.ts:10420). Si vacío,
# se cae al fallback `praeventio_confidential_v1:${tenantId}` — válido
# pero NO rotable; setear en prod a un random base64 32 bytes.
CONFIDENTIAL_REPORTS_SALT=

# QR_SIG_SECRET: secret HMAC para firmar QR codes generados por
# sprintK routes (firma temporal de attendance/credenciales). Si vacío,
# las verificaciones HMAC fallan silenciosamente. Min 32 chars.
QR_SIG_SECRET=

# QR_ACK_HMAC_SECRET: secret HMAC para acknowledgements de QR codes
# escaneados (qrAck.ts route). Separado de QR_SIG_SECRET para permitir
# rotación independiente. Min 32 chars. Si vacío, /api/qr/ack rechaza.
QR_ACK_HMAC_SECRET=

# VAULT_BUCKET: GCS bucket donde se almacenan documentos del Health
# Vault del trabajador (occupationalContext.ts:766). Default fallback
# en código si vacío. Setear en prod al bucket dedicado del tenant.
VAULT_BUCKET=

# === SECTION: WebAuthn (passkeys / firma electrónica avanzada) ===

# WEBAUTHN_RPID: Relying Party ID — typically el dominio del host sin
# protocolo ni puerto (ej: 'praeventio.app'). Debe coincidir con
# `window.location.hostname` del frontend o el navegador rechazará el
# challenge. Usado por sitebookSignRoutes (DS 76 advanced signature).
WEBAUTHN_RPID=<praeventio.app>

# WEBAUTHN_ORIGIN: Origin URL completa permitida en la attestation
# (ej: 'https://app.praeventio.app'). Validada server-side contra el
# clientDataJSON de la respuesta del authenticator.
WEBAUTHN_ORIGIN=<https://app.praeventio.app>

# === SECTION: SUSESO API (Chile — Superintendencia Seguridad Social) ===

# SUSESO_API_KEY: API key server-side para presentar formularios DIAT/
# DIEP/Encuestas SUSESO (susesoApiClient.ts). NUNCA exponer al frontend
# — solo route handlers server-side via api/suseso/* deben usarla.
SUSESO_API_KEY=

# === SECTION: OpenAQ (calidad del aire externo) ===

# OPENAQ_API_KEY: API key opcional de OpenAQ v3 (externalClimate.ts).
# Si vacío, se usa endpoint anónimo con rate limits más bajos. Útil
# para tenants en mining/sites con monitoreo de PM10/PM2.5 continuo.
OPENAQ_API_KEY=

# === SECTION: Desarrollo y testing local (NO setear en prod) ===

# FIRESTORE_EMULATOR_HOST: si está seteado, los tests *.firestore.test
# y los scripts de seed apuntan al emulador en vez de prod (default
# 'localhost:8080' cuando se ejecuta `firebase emulators:start`).
# Detectado automáticamente por firebase-admin SDK.
# FIRESTORE_EMULATOR_HOST=localhost:8080

# GCLOUD_PROJECT: project ID que recibe el firebase-admin SDK cuando
# corre contra el emulador. En prod se usa GCP_PROJECT_ID; esta
# variante existe para satisfacer la convención esperada por las
# librerías de Google Cloud cuando emulators está activo.
# GCLOUD_PROJECT=praeventio-emulator-dev

# VITE_MODE: alternativa a `import.meta.env.MODE` para forzar 'test'
# en suites de Vitest que se ejecutan fuera de `vite test`. Solo
# tests — no usar en runtime productivo.
# VITE_MODE=test

# === SECTION: Vite client env (import.meta.env.VITE_*) ===

# VITE_APP_URL: URL canónica de la app frontend (alias de APP_URL para
# el bundle Vite — Vite solo expone vars con prefijo VITE_). Usado por
# componentes client-side que necesitan construir links absolutos.
VITE_APP_URL=<https://app.praeventio.net>

# VITE_APP_ENV: entorno declarado del bundle frontend ('production' |
# 'staging' | 'development'). Usado por sentry init + feature gating
# client-side. Default deriva de import.meta.env.MODE.
VITE_APP_ENV=development

# VITE_SLM_OFFLINE_ENABLED: feature flag client del SLM offline (mismo
# rol que SLM_OFFLINE_ENABLED pero expuesto al bundle Vite). Allowed
# values: true, false. B14: default unset = TRUE (kill-switch: false).
VITE_SLM_OFFLINE_ENABLED=true

# VITE_SYSTEM_ENGINE_ENABLED: activa el SystemEngine en el cliente
# (provider montado en AppProviders). Cuando true, arranca la
# automatización geofence→SOS + tier-reactivity (registra políticas,
# suscribe al bus de eventos, ejecuta acciones). Default unset = false
# (off): el provider queda inerte/passthrough hasta que ops lo habilite.
# Habilítalo SOLO tras validar las políticas en staging — dispara
# emergencias automáticas. Allowed values: true, false.
VITE_SYSTEM_ENGINE_ENABLED=false

# === SECTION: Monetización (AdMob + AdSense) ===

# AdMob (mobile native) — interstitial ad unit IDs por plataforma.
# Obtenibles en https://apps.admob.com/ → App → Ad units.
# Server-side / build only — el adapter los lee via Vite import.meta.env
# y los pasa al plugin nativo @capacitor-community/admob.
VITE_ADMOB_ANDROID_INTERSTITIAL=<optional-ca-app-pub-...>
VITE_ADMOB_IOS_INTERSTITIAL=<optional-ca-app-pub-...>

# AdSense (web) — script tag IDs para mostrar ads en builds web.
# https://www.google.com/adsense/ → Ads → By ad unit.
VITE_ADSENSE_CLIENT=<optional-ca-pub-...>
VITE_ADSENSE_SLOT=<optional-slot-id>
