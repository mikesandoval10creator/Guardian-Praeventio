# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenWeatherMap API Key
VITE_OPENWEATHER_API_KEY=

# Pinecone Vector Database (RAG)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=praeventio-guard

# Firebase Cloud Messaging (FCM)
VITE_FIREBASE_VAPID_KEY=

# Server Secrets
SESSION_SECRET=
IOT_WEBHOOK_SECRET=

# Round 18 R6 — emergency rollback for the canonical-JSON HMAC migration.
# When set to "1", /api/telemetry/ingest and /api/billing/webhook/mercadopago
# will, on a primary canonical-form mismatch, RE-ATTEMPT verification under
# the legacy `JSON.stringify(req.body)` contract. Default OFF. Every
# successful legacy match emits a `*_hmac_legacy_fallback` warn log so
# operators can identify clients still on the old path. Remove once
# telemetry shows zero hits — DO NOT leave this on indefinitely (it
# defeats the cross-producer-portability fix this round shipped).
LEGACY_HMAC_FALLBACK=

# MercadoPago IPN HMAC secret (R18 R2). HMAC-SHA256 over the RFC 8785
# canonical-JSON body. Producers MUST canonicalise before signing (see
# src/server/middleware/canonicalBody.ts).
MP_IPN_SECRET=

# MP_OIDC_CLOCK_TOLERANCE_SEC: clock skew tolerance in seconds for JWT exp
# claim verification. Default 0 (strict). Set to 30-120 in environments
# with NTP drift. Higher values widen replay attack window.
MP_OIDC_CLOCK_TOLERANCE_SEC=

# Webpay / Transbank — pasarela de pagos CL (web).
# Para DEV / CI / E2E: NO setear estas vars — el adapter usa por defecto
# las credenciales de "Tienda de Integración" embebidas en transbank-sdk
# (IntegrationCommerceCodes.WEBPAY_PLUS + IntegrationApiKeys.WEBPAY).
# Para PROD: aplicar a https://www.transbank.cl/ y poblar las 3 vars.
# Detalles + tarjetas de prueba: docs/runbooks/TRANSBANK_RUNBOOK.md
WEBPAY_COMMERCE_CODE=
WEBPAY_API_KEY=
WEBPAY_ENV=integration

# APP_BASE_URL: Used to build Webpay return URL (`${APP_BASE_URL}/billing/webpay/return`).
# Dev: http://localhost:5173 (Vite). Prod: canonical app URL (https://app.praeventio.net).
APP_BASE_URL=

# Google Play Billing Integration
# Package name of your Android app (e.g., com.praeventio.guard)
GOOGLE_PLAY_PACKAGE_NAME=
# Full JSON string of the service account file from Google Cloud Console
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# The Pub/Sub topic name for RTDN notifications
GOOGLE_PLAY_RTDN_TOPIC=

# Sentry (error tracking + performance traces) — Phase 3 of master plan.
# Project "guardian-praeventio" in org "praeventio" (us region) is provisioned.
# Get the real DSN from https://praeventio.sentry.io/settings/projects/guardian-praeventio/keys/
# In prod, store both DSN values as Secret Manager secrets — do NOT commit a real .env.
# Backend (Node, server.ts → @sentry/node):
SENTRY_DSN=https://<public-key>@<org-id>.ingest.us.sentry.io/<project-id>
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development
# Frontend (Vite, src/lib/sentry.ts → @sentry/react). Same DSN, VITE_ prefix
# required because Vite only exposes env vars whose names start with VITE_.
VITE_SENTRY_DSN=https://<public-key>@<org-id>.ingest.us.sentry.io/<project-id>
VITE_APP_VERSION=dev
