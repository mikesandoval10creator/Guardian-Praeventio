# .gcloudignore — keep the Cloud Build context lean.
#
# Cloud Build uploads the working directory minus everything matched here
# (gitignore-style). Anything not needed at build time should be excluded.
# Patterns roughly follow .gitignore + .dockerignore + extra build noise.

# ── VCS / IDE ────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.github/
.vscode/
.idea/

# ── Local secrets ────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Node ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.eslintcache

# ── Build artefacts (generated inside the build) ─────────────────────────
dist/
build/
out/
.next/
coverage/
.nyc_output/
.size-limit*.json.bak

# ── Tests / dev tooling not needed for image build ───────────────────────
tests/
e2e/
playwright-report/
test-results/
.stryker-tmp/

# ── Telemetry / agent scratch ────────────────────────────────────────────
.claude/
.telemetry/
.cursor/
.aider*

# ── Docs (keep README.md only — image labels reference repo) ─────────────
docs/
*.md
!README.md

# ── Scripts intentionally NOT excluded (Dockerfile may reference scripts/)
# Comment out the next line if you ever need to keep tools/ for an image:
tools/

# ── Mobile / native shells (Cloud Build does not produce APK/IPA) ────────
android/
ios/
fastlane/
*.apk
*.aab
*.ipa

# ── Misc ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
