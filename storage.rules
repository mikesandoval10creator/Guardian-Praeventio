rules_version = '2';

// Praeventio Guard — Cloud Storage rules (Phase 5 · "make real" remediation).
//
// ── Why this file was rewritten (2026-06-09) ──────────────────────────────
// The previous rules described an ASPIRATIONAL scheme that NOTHING in the app
// used: `tenants/{tid}/{medical,legal,evidence,general}/...` + a
// `quarantine/{tid}/...` → AV-scan → tenants pipeline. No backend ever built
// the AV scanner, and ALL 10+ client uploaders write to entirely different,
// REAL paths (`projects/{pid}/...`, `ai_reports/{pid}/...`, `blueprints/{pid}/...`,
// `documents/{workerId}/...`, `suseso_reports/{pid}/...`, `reconstructions/{pid}/...`).
// Those real paths matched NO rule → every upload fell to default-deny, so file
// upload was silently broken app-wide.
//
// ── Why project-keyed, not tenant-keyed ──────────────────────────────────
// Cloud Storage rules CANNOT read Firestore, so per-resource authorization can
// only consult the verified token's custom claims. Investigation of the real
// auth model (src/services/auth/customClaims.ts, ProjectContext.createProject):
//   • Standard provisioning mints `role` + `assignedSiteIds` (a list of the
//     PROJECT ids the user is assigned to). It does NOT mint a `tenantId`
//     claim, and `createProject` does not stamp `tenantId` on projects.
//   • So the app's real, populated authorization claim is `assignedSiteIds`
//     (project ids) — NOT tenant. Gating storage on `isMemberOfTenant(tid)`
//     would default-deny uploads for essentially every standard user.
// Therefore the real upload paths are kept (project-keyed) and gated by the
// `assignedSiteIds` claim, mirroring the server's `resolveAssignedSitesCheck`
// fast-path. `memberOfSite()` is conservative (see below): it TIGHTENS for
// claim-bearing users and never permanently blocks a legacy user.
//
// ── Deferred follow-ups (documented, not silently dropped) ────────────────
//   • Anti-virus / quarantine pipeline: the old aspirational design is removed.
//     A real AV scan (ClamAV/VirusTotal via a server-side onFinalize trigger)
//     is the proper content-integrity defense and is tracked as a follow-up.
//   • Full claim-backed isolation: once `assignedSiteIds` is universally
//     provisioned (and/or a real `tenantId` claim exists), the `claim absent →
//     allow` legacy escape hatch in `memberOfSite()` can be removed.

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // Best-effort project membership via the `assignedSiteIds` claim.
    // Storage rules cannot read Firestore, so this is the only membership
    // signal available. Conservative, mirroring resolveAssignedSitesCheck:
    //   • claim ABSENT            → allow (legacy/pre-migration compat — the
    //                               Firestore metadata doc + unguessable path +
    //                               signed downloadURL remain the boundary).
    //   • claim present, in list  → allow (verified member).
    //   • claim present, NOT in   → DENY (the isolation boundary for migrated
    //                               users; self-heals on the next token refresh
    //                               if the claim was merely stale).
    function memberOfSite(projectId) {
      return isSignedIn() && (
        !('assignedSiteIds' in request.auth.token) ||
        (request.auth.token.assignedSiteIds is list &&
         projectId in request.auth.token.assignedSiteIds)
      );
    }

    function isUnder(bytes) {
      return request.resource.size != null && request.resource.size < bytes;
    }

    // Permissive-but-bounded content set covering every real uploader: PDFs
    // (reports/SUSESO/PTS/EPP actas/emergency plans), images (blueprints,
    // SafetyFeed photos, avatars), video + audio (CrisisChat voice notes),
    // 3D models (reconstructions GLB/USDZ — often served as octet-stream),
    // and arbitrary worker documents (office formats). Byte-level content
    // integrity is the deferred AV-scan's job, not the rules layer's.
    function isAllowedUpload() {
      return request.resource.contentType != null && (
        request.resource.contentType.matches('application/pdf') ||
        request.resource.contentType.matches('image/.*') ||
        request.resource.contentType.matches('video/.*') ||
        request.resource.contentType.matches('audio/.*') ||
        request.resource.contentType.matches('model/.*') ||
        request.resource.contentType.matches('application/octet-stream') ||
        request.resource.contentType.matches('application/zip') ||
        request.resource.contentType.matches('application/vnd..*') ||
        request.resource.contentType.matches('application/msword') ||
        request.resource.contentType.matches('text/.*')
      );
    }

    // ── Project-scoped uploads (the primary real path) ──────────────────────
    // projects/{pid}/... : ProjectDocuments, AddDocumentModal, PTSGenerator,
    // TacticalOnboardingModal (workers/{wid}/documents), AssignEPPModal (EPP
    // actas), EmergencyGenerator (PDF), CrisisChat (audio/), SafetyFeed (feed/),
    // OfflineSyncManager replays. <=100 MB (video/audio/model headroom).
    match /projects/{projectId}/{allPaths=**} {
      allow read: if memberOfSite(projectId);
      allow create, update: if memberOfSite(projectId) && isAllowedUpload() && isUnder(100 * 1024 * 1024);
      // F7 (founder decision 2026-07-02): project files ARE the
      // compliance/legal trail (PTS, EPP actas, emergency plans, incident
      // photos) — a client delete is an evidence-destruction primitive.
      // Governed removals are server-side only (Admin SDK + audit_logs).
      allow delete: if false;
    }

    // AI-generated report PDFs (ReportGenerator, EmergencyPlanGenerator).
    match /ai_reports/{projectId}/{allPaths=**} {
      allow read: if memberOfSite(projectId);
      allow create, update: if memberOfSite(projectId) && isAllowedUpload() && isUnder(50 * 1024 * 1024);
      allow delete: if false;
    }

    // Blueprint snapshots (BlueprintViewer PNG).
    match /blueprints/{projectId}/{allPaths=**} {
      allow read: if memberOfSite(projectId);
      allow create, update: if memberOfSite(projectId) && isAllowedUpload() && isUnder(50 * 1024 * 1024);
      // F7 (2026-07-02): blueprint snapshots back findings/investigations
      // — evidence; no client deletes (see projects/ rationale above).
      allow delete: if false;
    }

    // SUSESO DIAT/DIEP report PDFs (SusesoReports) — compliance evidence,
    // PDF only, immutable once written (no client update/delete).
    // `resource == null` makes the immutability bulletproof: the Storage
    // emulator (and prod) classify an overwrite of an existing object as
    // `create`, so gating only on `update` would let a member silently replace
    // a filed SUSESO PDF. Requiring no pre-existing object denies overwrites.
    match /suseso_reports/{projectId}/{allPaths=**} {
      allow read: if memberOfSite(projectId);
      allow create: if resource == null
        && memberOfSite(projectId)
        && request.resource.contentType == 'application/pdf'
        && isUnder(25 * 1024 * 1024);
      allow update, delete: if false;
    }

    // On-device photogrammetry digital-twin models (onDeviceAdapter GLB/USDZ).
    // Large binary blobs (model/* or octet-stream); <=200 MB.
    //
    // V4 hardening (2026-06-22): `isAllowedUpload()` is now required on create
    // and update. The original comment ("skipping isAllowedUpload — GLB/USDZ
    // often arrive as application/octet-stream") is no longer a blocker because
    // isAllowedUpload() ALREADY covers both `model/.*` (gltf-binary,
    // vnd.usdz+zip) and `application/octet-stream`. The omission was therefore
    // safe in practice but left the door open for arbitrary content types (e.g.
    // application/x-msdownload). Adding the check tightens the create rule
    // without blocking any legitimate 3D asset upload.
    match /reconstructions/{projectId}/{allPaths=**} {
      allow read: if memberOfSite(projectId);
      allow create, update: if memberOfSite(projectId) && isAllowedUpload() && isUnder(200 * 1024 * 1024);
      allow delete: if memberOfSite(projectId);
    }

    // Whether the caller's token carries an admin/supervisor-tier role claim.
    // Storage rules cannot read Firestore, so this is the only role signal
    // available here. Mirrors the Firestore `hasSupervisorTierRole()` helper
    // (roles from src/types/roles.ts via firestore.rules).
    // V5 (2026-07-02, audit §3.2): guard `'role' in ...` BEFORE the `in`
    // comparison. Reading an absent map key raises a rules error that
    // propagates as deny — functionally fail-closed, but it logs the
    // `Property role is undefined on object` warning on every claim-less
    // request (visible on each `test:rules` run) and is fragile. The
    // presence guard makes the deny explicit and silent. (`email_verified`
    // is already asserted by `isSignedIn()` — dropped as redundant.)
    function isAdminOrSupervisorTier() {
      return isSignedIn() &&
        'role' in request.auth.token &&
        request.auth.token.role in [
          'admin', 'gerente',
          'supervisor', 'prevencionista', 'director_obra', 'medico_ocupacional'
        ];
    }

    // Worker documents attached by a supervisor (DocsModal ->
    // documents/{workerId}/...). `workerId` is a worker-doc id, NOT a site id
    // nor a caller uid, so this path cannot be assignedSiteIds- or owner-gated
    // for read — the Firestore metadata doc at
    // projects/{pid}/workers/{wid}/documents/{did} is the authoritative ACL,
    // and the signed downloadURL (short-lived, scoped to this exact path) keeps
    // unauthenticated access closed.
    //
    // V3 (2026-06-22) restricted delete to admin/supervisor tier. F7
    // (founder decision 2026-07-02) SUPERSEDES it: worker documents are
    // legal evidence (contracts, certs, EPP/SUSESO records — the DS 44 /
    // Ley 16.744 trail), and a client-side delete is an evidence-
    // destruction primitive, so delete is DENIED for every client — same
    // posture as `suseso_reports` above. Governed removals (data-subject
    // erasure per Ley 19.628/21.719, mistaken uploads) go through the
    // server (Admin SDK bypasses rules) with an audit_logs row. The UI
    // offers "Archivar" (metadata `archived: true`, hide-only) instead.
    // Read stays at `isSignedIn()` because `workerId` is not a uid or
    // project id — we cannot gate per-owner without Firestore access; the
    // unguessable path + signed URL remain the boundary for reads.
    match /documents/{workerId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isAllowedUpload() && isUnder(50 * 1024 * 1024);
      allow delete: if false;
    }

    // Worker personal vault — strictly per-uid private (self-service uploads).
    // Kept from the prior rules; the only uid-keyed namespace.
    match /workers/{uid}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == uid && isUnder(50 * 1024 * 1024);
    }

    // Default-deny: every other path is explicitly closed.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
