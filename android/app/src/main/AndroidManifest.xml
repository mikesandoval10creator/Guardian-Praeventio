<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- App Links (Sprint 21 — ADR-0013 deep linking).
                 Requires /.well-known/assetlinks.json served by server.ts.
                 See docs/deep-linking-runbook.md for keystore fingerprint setup. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="praeventio.app" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Sprint mobile FGS — @capawesome-team/capacitor-android-foreground-service.
             Declares the native foreground service used by the lone-worker
             check-in flow + health/location sustained tracking. The two
             `foregroundServiceType` flags must match the permission set
             declared above (`FOREGROUND_SERVICE_LOCATION` +
             `FOREGROUND_SERVICE_HEALTH`). See:
             https://developer.android.com/develop/background-work/services/fgs/service-types
        -->
        <service
            android:name="io.capawesome.capacitorjs.plugins.foregroundservice.AndroidForegroundService"
            android:foregroundServiceType="location|health"
            android:exported="false" />
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Sprint mobile FGS — required permissions for the
         @capawesome-team/capacitor-android-foreground-service plugin used by
         the lone-worker check-in foreground service.

         FOREGROUND_SERVICE                — base permission (SDK 28+).
         FOREGROUND_SERVICE_LOCATION       — required when foregroundServiceType
                                             includes "location" (SDK 34+).
         FOREGROUND_SERVICE_HEALTH         — required when foregroundServiceType
                                             includes "health" (SDK 34+).
         ACCESS_BACKGROUND_LOCATION        — needed so the worker location
                                             keeps updating when the app is
                                             not in the foreground.
         POST_NOTIFICATIONS                — needed on SDK 33+ to show the
                                             persistent FGS notification.
         WAKE_LOCK                         — keeps the service alive while
                                             check-in interval ticks. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- AUDIT-2026-06 B21 — runtime permissions no plugin manifest provides.

         ACCESS_FINE_LOCATION / ACCESS_COARSE_LOCATION — required by
             @capacitor/geolocation (its plugin manifest deliberately does
             NOT declare them). Without FINE, ACCESS_BACKGROUND_LOCATION
             above is inert and the SOS / lone-worker GPS fix never
             resolves on device.
         CAMERA — the QR scanner (html5-qrcode) and the on-device
             biometric/pose flows run inside the WebView via getUserMedia;
             Android only surfaces the WebView permission prompt when the
             app itself holds CAMERA.
         RECORD_AUDIO + MODIFY_AUDIO_SETTINGS — same class of bug as CAMERA,
             for the microphone. Capacitor's BridgeWebChromeClient
             (onPermissionRequest) maps the WebView's AUDIO_CAPTURE request
             to BOTH permissions and calls request.deny() unless EVERY
             permission in the array is granted — and Android denies any
             permission the manifest does not declare. Declaring only one of
             the two leaves the mic just as dead. Needed by:
             NoiseMonitor (decibel measurement, DS 594 hygiene),
             CrisisChat (emergency voice message — life-safety path),
             GuardianVoiceAssistant (voice input).

         BLE permissions (BLUETOOTH_SCAN/CONNECT/ADVERTISE + legacy) are
         intentionally NOT declared here — they merge in from the
         @praeventio/capacitor-mesh plugin manifest now that the package
         is included in capacitor.settings.gradle. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
</manifest>
