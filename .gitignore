reports/
tsconfig.tsbuildinfo
.DS_Store
*.log
.env*
!.env.example

# Firebase config — contains project credentials, use env vars in production
firebase-applet-config.json

# Agent multi-paralelo worktrees scratch (ver lección plan vivo línea 1970)
.claude/worktrees/
*.tmp.ts

# Sprint 40 — gstack pirate adoption: share commands/settings via repo
# (per Garry Tan team-mode pattern). Local outputs stay private.
.claude/agents-output/
.claude/launch.json
# Per-developer agent skills (ponytail, superpowers, etc.) live on disk only —
# swept into git by accident in #1039; not part of the repo harness (commands +
# settings.json ARE shared, skills are not).
.claude/skills/
# §2.28 (2026-05-21) — más Claude local state que caía al staging por
# accident. Lock + per-user settings nunca van al repo.
.claude/scheduled_tasks.lock
.claude/settings.local.json
# Per-user Claude PR-templates + superpowers plan drafts (notes, no project).
docs/.pr-templates/
docs/superpowers/
# Reports from canary/security/retro scripts — local-only output
reports/canary/
reports/security/
reports/retro/

# Playwright local artifacts
playwright-report/
test-results/

# Stryker mutation testing artifacts
.stryker-tmp/
reports/mutation/

# Bucket O (Brecha B) — SLM offline weights. The TinyLlama 1.1B Q4 ONNX
# file is ~600 MB and is fetched via `scripts/download-slm-model.mjs` /
# served from CDN in production. Never commit weights to the repo.
public/models/slm/*.onnx
public/models/slm/*.onnx.partial

# Sprint 54 ext — Pre-packaged SLM bundle. Release pipeline drops the
# verified `.onnx` + `.onnx_data` here so the runtime serves them as
# same-origin assets (zero network, even on first launch). Never
# commit the binaries; only the README + path layout lives in git.
public/models/*/*.onnx
public/models/*/*.onnx_data
public/models/*/*.partial

# Bucket PP — MediaPipe Pose Landmarker assets (Sprint 25 gaps cleanup).
# Bajados por `scripts/download-mediapipe-models.mjs` (prebuild hook).
# Local-first hosting para offline/GDPR; servidos desde nuestro origen
# en prod. Nunca committear los blobs.
public/models/mediapipe/*.task
public/models/mediapipe/*.task.partial
public/models/mediapipe/*.wasm
public/models/mediapipe/*.wasm.partial
public/models/mediapipe/*.js
public/models/mediapipe/*.js.partial

# Dev-server / verification markers (sesion cowork local tooling)
dev-server*.txt
verificar*.txt

# Audit scan artifacts (generated by local tooling, not committed)
audit_chunks.json
audit_scan_results.json
