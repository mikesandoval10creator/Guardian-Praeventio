{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a user of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "supervisor", "worker"] },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "subscription": {
          "type": "object",
          "properties": {
            "planId": { "type": "string", "enum": ["free", "basic", "premium", "enterprise"] },
            "expiryDate": { "type": "string", "format": "date-time" },
            "status": { "type": "string", "enum": ["active", "expired", "canceled", "pending"] },
            "purchaseToken": { "type": "string" },
            "orderId": { "type": "string" },
            "updatedAt": { "type": "string", "format": "date-time" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project/Workspace",
      "description": "A workspace or project where safety management occurs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Worker": {
      "title": "Worker",
      "description": "A worker associated with a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "position": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "coordinates": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "hasArt22": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "name", "position", "status"]
    },
    "Node": {
      "title": "Knowledge Node",
      "description": "An atomic unit of knowledge in the Risk Network system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Trabajador", "Máquina", "Riesgo", "Normativa", "EPP", "Inspección", "Incidente", "Costo", "Reporte", "Tarea", "Documento", "Higiene", "Medicina", "Ergonomía", "Hallazgo", "Auditoría", "Proyecto", "Emergencia", "Activo", "Capacitación"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "connections": { "type": "array", "items": { "type": "string" }, "description": "IDs of other connected nodes." },
        "metadata": { "type": "object" },
        "projectId": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "description"]
    },
    "EmergencyMessage": {
      "title": "Emergency Message",
      "description": "A message sent during a crisis.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "sender": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "alert", "emergency"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "sender", "role", "text", "type", "timestamp"]
    },
    "EmergencyCheckIn": {
      "title": "Emergency Check-In",
      "description": "A worker's status during an emergency.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "workerId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["safe", "danger", "unknown"] },
        "lastLocation": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "workerId", "name", "status", "timestamp"]
    },
    "EPPItem": {
      "title": "EPP Item",
      "description": "A piece of Personal Protective Equipment in the catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "required": { "type": "boolean" },
        "stock": { "type": "number" },
        "ispCertification": { "type": "string" },
        "expirationDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "name", "category", "stock"]
    },
    "EPPAssignment": {
      "title": "EPP Assignment",
      "description": "Record of an EPP item assigned to a worker.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "eppItemId": { "type": "string" },
        "eppItemName": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "replaced", "expired"] },
        "condition": { "type": "string", "enum": ["Nuevo", "Bueno", "Desgastado", "Dañado"] }
      },
      "required": ["projectId", "workerId", "eppItemId", "assignedAt", "status"]
    },
    "TrainingSession": {
      "title": "Training Session",
      "description": "A safety training session for workers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "status": { "type": "string", "enum": ["scheduled", "completed"] },
        "attendees": { "type": "array", "items": { "type": "string" } },
        "projectId": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "points": { "type": "number" },
        "isCurated": { "type": "boolean" }
      },
      "required": ["title", "date", "status"]
    },
    "SafetyPost": {
      "title": "Safety Post",
      "description": "A social post related to safety.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["SafetyMoment", "Tip", "SuccessStory", "Warning"] },
        "imageUrl": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "projectId": { "type": "string" }
      },
      "required": ["userId", "content", "type", "createdAt"]
    },
    "Report": {
      "title": "Inspection Report",
      "description": "An inspection report, audit, or safety observation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["Incidente", "Auditoría", "Observación"] },
        "status": { "type": "string", "enum": ["Pendiente", "Cerrado", "En Proceso"] },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "projectId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "type", "status", "projectId"]
    },
    "SafetyControl": {
      "title": "Safety Control",
      "description": "A preventive or protective safety control measure.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["Predictivo", "Preventivo", "Reactivo"] },
        "status": { "type": "string", "enum": ["Operativo", "En Revisión", "Crítico"] },
        "efficiency": { "type": "number" },
        "projectId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "status", "projectId"]
    },
    "Material": {
      "title": "Safety Material",
      "description": "Safety materials, tools, or resources.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Herramienta", "Insumo", "Equipo"] },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "projectId": { "type": "string" }
      },
      "required": ["name", "type", "stock", "projectId"]
    },
    "TelemetryEvent": {
      "title": "Telemetry Event",
      "description": "An event captured by IoT sensors.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "source": { "type": "string" },
        "metric": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "status": { "type": "string", "enum": ["normal", "warning", "critical"] },
        "projectId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "source", "metric", "value", "timestamp"]
    },
    "Asset": {
      "title": "Asset",
      "description": "A physical asset like machinery or tools.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Maquinaria", "Vehículo", "Herramienta"] },
        "status": { "type": "string", "enum": ["Operativo", "En Mantenimiento", "Fuera de Servicio"] },
        "lastMaintenance": { "type": "string", "format": "date-time" },
        "nextMaintenance": { "type": "string", "format": "date-time" },
        "operatorId": { "type": "string" },
        "projectId": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "status", "projectId"]
    },
    "Location": {
      "title": "Device Location",
      "description": "GPS location of a user's device.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "accuracy": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "projectId", "latitude", "longitude", "timestamp"]
    },
    "Transaction": {
      "title": "Billing Transaction",
      "description": "Record of a Google Play Billing transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "orderId": { "type": "string" },
        "packageName": { "type": "string" },
        "productId": { "type": "string" },
        "purchaseTime": { "type": "string", "format": "date-time" },
        "purchaseState": { "type": "number", "description": "0: Purchased, 1: Canceled, 2: Pending" },
        "purchaseToken": { "type": "string" },
        "type": { "type": "string", "enum": ["subscription", "one_time"] },
        "status": { "type": "string", "enum": ["verified", "pending", "failed", "refunded"] },
        "rawResponse": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "orderId", "purchaseToken", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Google Play Billing transactions."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project workspace documents."
    },
    "/projects/{projectId}/workers/{workerId}": {
      "schema": "Worker",
      "description": "Workers within a specific project."
    },
    "/nodes/{nodeId}": {
      "schema": "Node",
      "description": "Risk Network knowledge nodes."
    },
    "/projects/{projectId}/emergency_messages/{messageId}": {
      "schema": "EmergencyMessage",
      "description": "Messages sent during an emergency."
    },
    "/projects/{projectId}/emergency_checkins/{checkinId}": {
      "schema": "EmergencyCheckIn",
      "description": "Worker check-ins during an emergency."
    },
    "/projects/{projectId}/epp_items/{itemId}": {
      "schema": "EPPItem",
      "description": "EPP catalog items for a project."
    },
    "/projects/{projectId}/epp_assignments/{assignmentId}": {
      "schema": "EPPAssignment",
      "description": "EPP assignments to workers."
    },
    "/projects/{projectId}/trainings/{trainingId}": {
      "schema": "TrainingSession",
      "description": "Training sessions for a project."
    },
    "/projects/{projectId}/safety_posts/{postId}": {
      "schema": "SafetyPost",
      "description": "Safety social posts for a project."
    },
    "/projects/{projectId}/assets/{assetId}": {
      "schema": "Asset",
      "description": "Assets for a project."
    },
    "/projects/{projectId}/reports/{reportId}": {
      "schema": "Report",
      "description": "Inspection reports for a project."
    },
    "/projects/{projectId}/controls/{controlId}": {
      "schema": "SafetyControl",
      "description": "Safety controls for a project."
    },
    "/projects/{projectId}/materials/{materialId}": {
      "schema": "Material",
      "description": "Safety materials for a project."
    },
    "/telemetry_events/{eventId}": {
      "schema": "TelemetryEvent",
      "description": "Global telemetry events stream."
    },
    "/projects/{projectId}/locations/{locationId}": {
      "schema": "Location",
      "description": "Device locations for users in a project."
    }
  }
}
