{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a user of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "supervisor", "worker"] },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project/Workspace",
      "description": "A workspace or project where safety management occurs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Worker": {
      "title": "Worker",
      "description": "A worker associated with a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "position": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "coordinates": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "name", "position", "status"]
    },
    "Node": {
      "title": "Knowledge Node",
      "description": "An atomic unit of knowledge in the Zettelkasten system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Trabajador", "Máquina", "Riesgo", "Normativa", "EPP", "Inspección", "Incidente", "Costo", "Reporte", "Tarea", "Documento", "Higiene", "Medicina", "Ergonomía", "Hallazgo", "Auditoría", "Proyecto", "Emergencia", "Activo", "Capacitación"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "connections": { "type": "array", "items": { "type": "string" }, "description": "IDs of other connected nodes." },
        "metadata": { "type": "object" },
        "projectId": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "description"]
    },
    "EmergencyMessage": {
      "title": "Emergency Message",
      "description": "A message sent during a crisis.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "sender": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "alert", "emergency"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "sender", "role", "text", "type", "timestamp"]
    },
    "EmergencyCheckIn": {
      "title": "Emergency Check-In",
      "description": "A worker's status during an emergency.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "workerId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["safe", "danger", "unknown"] },
        "lastLocation": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "workerId", "name", "status", "timestamp"]
    },
    "EPPItem": {
      "title": "EPP Item",
      "description": "A piece of Personal Protective Equipment in the catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "required": { "type": "boolean" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "name", "category", "stock"]
    },
    "EPPAssignment": {
      "title": "EPP Assignment",
      "description": "Record of an EPP item assigned to a worker.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "eppItemId": { "type": "string" },
        "eppItemName": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "replaced", "expired"] }
      },
      "required": ["projectId", "workerId", "eppItemId", "assignedAt", "status"]
    },
    "TrainingSession": {
      "title": "Training Session",
      "description": "A safety training session for workers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "status": { "type": "string", "enum": ["scheduled", "completed"] },
        "attendees": { "type": "array", "items": { "type": "string" } },
        "projectId": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "points": { "type": "number" },
        "isCurated": { "type": "boolean" }
      },
      "required": ["title", "date", "status"]
    },
    "SafetyPost": {
      "title": "Safety Post",
      "description": "A social post related to safety.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["SafetyMoment", "Tip", "SuccessStory", "Warning"] },
        "imageUrl": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "projectId": { "type": "string" }
      },
      "required": ["userId", "content", "type", "createdAt"]
    },
    "Asset": {
      "title": "Asset",
      "description": "A physical asset like machinery or tools.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Maquinaria", "Vehículo", "Herramienta"] },
        "status": { "type": "string", "enum": ["Operativo", "En Mantenimiento", "Fuera de Servicio"] },
        "lastMaintenance": { "type": "string", "format": "date-time" },
        "nextMaintenance": { "type": "string", "format": "date-time" },
        "operatorId": { "type": "string" },
        "projectId": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "status", "projectId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project workspace documents."
    },
    "/projects/{projectId}/workers/{workerId}": {
      "schema": "Worker",
      "description": "Workers within a specific project."
    },
    "/nodes/{nodeId}": {
      "schema": "Node",
      "description": "Zettelkasten knowledge nodes."
    },
    "/projects/{projectId}/emergency_messages/{messageId}": {
      "schema": "EmergencyMessage",
      "description": "Messages sent during an emergency."
    },
    "/projects/{projectId}/emergency_checkins/{checkinId}": {
      "schema": "EmergencyCheckIn",
      "description": "Worker check-ins during an emergency."
    },
    "/projects/{projectId}/epp_items/{itemId}": {
      "schema": "EPPItem",
      "description": "EPP catalog items for a project."
    },
    "/projects/{projectId}/epp_assignments/{assignmentId}": {
      "schema": "EPPAssignment",
      "description": "EPP assignments to workers."
    },
    "/projects/{projectId}/trainings/{trainingId}": {
      "schema": "TrainingSession",
      "description": "Training sessions for a project."
    },
    "/projects/{projectId}/safety_posts/{postId}": {
      "schema": "SafetyPost",
      "description": "Safety social posts for a project."
    },
    "/projects/{projectId}/assets/{assetId}": {
      "schema": "Asset",
      "description": "Assets for a project."
    }
  }
}
